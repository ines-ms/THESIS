def plot_demand_paths(paths, archetype, n_sample=200):
    months = np.arange(paths.shape[1])
    fig, axes = plt.subplots(1, 2, figsize=(16, 6))

    # --- Left panel: Fan chart ---
    ax1 = axes[0]
    idx = np.random.choice(paths.shape[0], min(n_sample, paths.shape[0]), replace=False)
    for i in idx:
        ax1.plot(months, paths[i]/1e9, alpha=0.03, color='steelblue', linewidth=0.5)

    for pct, alpha in [(5, 0.15), (25, 0.25)]:
        lo = np.percentile(paths, pct, axis=0)/1e9
        hi = np.percentile(paths, 100-pct, axis=0)/1e9
        ax1.fill_between(months, lo, hi, alpha=alpha, color='steelblue')
    ax1.plot(months, np.percentile(paths, 50, axis=0)/1e9,
             color='darkblue', linewidth=2, label='Median')
    ax1.axvline(x=12, color='grey', linestyle=':', linewidth=1,
                alpha=0.7, label='t=12 review')
    ax1.set_xlabel('Month')
    ax1.set_ylabel('Tokens (Billions/month)')
    ax1.set_title(f'{archetype.name} - {paths.shape[0]:,} Simulated Paths')
    ax1.legend(loc='upper left', fontsize=9)
    ax1.grid(True, alpha=0.3)
    ax1.set_xlim(0, T_MONTHS)
    # Use log scale on y-axis — handles skewed distributions properly
    ax1.set_yscale('log')
    y_lo = max(np.percentile(paths[:, -1], 1) / 1e9 * 0.5, 0.1)
    y_hi = np.percentile(paths[:, -1], 99) / 1e9 * 1.5
    ax1.set_ylim(y_lo, y_hi)

    # --- Right panel: Histogram with log-scale x-axis ---
    ax2 = axes[1]
    for t_idx, c, lbl in [(12,'green','Month 12'), (24,'orange','Month 24'),
                           (-1,'steelblue','Month 36')]:
        data = paths[:, t_idx] / 1e9
        data = data[data > 0]
        # Log-spaced bins for log-normal data
        lo_edge = max(data.min() * 0.8, 0.01)
        hi_edge = np.percentile(data, 99.5)
        bins = np.logspace(np.log10(lo_edge), np.log10(hi_edge), 60)
        ax2.hist(data, bins=bins, alpha=0.5, color=c, label=lbl, density=True)

    ax2.set_xscale('log')
    ax2.set_xlabel('Tokens (Billions/month) — log scale')
    ax2.set_ylabel('Density')
    ax2.set_title(f'{archetype.name} — Demand Distribution')
    ax2.legend(fontsize=9)
    ax2.grid(True, alpha=0.3, which='both')

    plt.tight_layout()
    safe_name = archetype.name.lower().replace(" ", "_").replace("/", "_")
    plt.savefig(f'demand_{safe_name}.png', dpi=150, bbox_inches='tight')
    plt.show()


