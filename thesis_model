def generate_demand_paths(archetype, n_sims=N_SIMULATIONS,
                          t_months=T_MONTHS, seed=RANDOM_SEED,
                          return_jumps=False):
    """
    Generate Monte Carlo demand paths using GBM + Poisson jumps.

    Discrete monthly model:
        D(t+1) = D(t) * exp[(mu_m - sigma_m^2/2) + sigma_m*Z + sum(jumps)]

    In log space this is AR(1) with unit root and drift:
        ln D(t+1) = ln D(t) + (mu_m - sigma_m^2/2) + sigma_m * Z(t)

    Returns: np.ndarray of shape (n_sims, t_months + 1)
             Column 0 = starting demand, columns 1..36 = months 1..36

    If return_jumps=True, also returns a boolean mask of shape (n_sims, t_months)
    indicating which months had at least one jump. This is used by the firm
    to exclude jump months from its parameter estimation, reflecting the
    backward-looking knowledge that the firm knows when it deployed use cases.
    """
    rng = np.random.default_rng(seed) if seed is not None else np.random.default_rng()

    mu_m = archetype.annual_drift / 12
    sigma_m = archetype.annual_volatility / np.sqrt(12)
    lambda_m = archetype.jump_frequency / 12

    paths = np.zeros((n_sims, t_months + 1))
    paths[:, 0] = archetype.starting_tokens_per_month

    # Pre-generate all random variables (vectorised)
    Z = rng.standard_normal((n_sims, t_months))
    N_jumps = rng.poisson(lambda_m, (n_sims, t_months))

    for t in range(t_months):
        # Diffusion component
        diffusion = (mu_m - 0.5 * sigma_m**2) + sigma_m * Z[:, t]

        # Jump component
        max_j = int(N_jumps[:, t].max()) if N_jumps[:, t].max() > 0 else 0
        jump_component = np.zeros(n_sims)
        if max_j > 0:
            all_sizes = rng.normal(archetype.jump_mean, archetype.jump_std,
                                   (n_sims, max_j))
            for j in range(max_j):
                mask = N_jumps[:, t] > j
                jump_component[mask] += all_sizes[mask, j]

        paths[:, t + 1] = paths[:, t] * np.exp(diffusion + jump_component)

    if return_jumps:
        jump_mask = N_jumps > 0  # (n_sims, t_months) boolean
        return paths, jump_mask
    return paths


