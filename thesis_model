def plot_strategy_comparison(n_boot=2000):
    """
    NEW FIGURE A: Strategy comparison bar chart with bootstrap 95% CIs.

    Headline visual for the thesis results section. Shows the five strategies
    on the y-axis with expected total cost on the x-axis, error bars from
    the bootstrap CIs, and the cloud-only baseline as a reference line.
    """
    print(f"\n{'='*80}")
    print(f"  FIGURE A — Strategy comparison bar chart with bootstrap CIs")
    print(f"{'='*80}")

    arch = ARCHETYPES["midsize_enterprise"]
    paths, jmask = generate_demand_paths(arch, return_jumps=True)
    results = evaluate_all_strategies(paths, arch, jump_mask=jmask)

    # For each strategy, extract the cost vector to bootstrap from.
    # Cloud-Only (P0) uses no_revision (it has no revision option);
    # all hybrid strategies use the re-estimation forecast cost.
    strategy_data = []
    for r in results:
        if r.percentile == 0:
            costs = r.cost_no_revision
        else:
            costs = r.cost_reest
        strategy_data.append({
            'name': r.name,
            'percentile': r.percentile,
            'costs': costs,
            'mean': costs.mean(),
        })

    # Bootstrap CI on each strategy's mean
    rng = np.random.default_rng(42)
    n_sims = len(strategy_data[0]['costs'])
    for sd in strategy_data:
        boot_means = np.array([
            sd['costs'][rng.integers(0, n_sims, n_sims)].mean()
            for _ in range(n_boot)
        ])
        sd['ci_lo'] = np.percentile(boot_means, 2.5)
        sd['ci_hi'] = np.percentile(boot_means, 97.5)

    cloud_mean = strategy_data[0]['mean']

    # Plot
    fig, ax = plt.subplots(figsize=(11, 6))
    names = [sd['name'] for sd in strategy_data]
    means = [sd['mean'] / 1e6 for sd in strategy_data]
    errs_lo = [(sd['mean'] - sd['ci_lo']) / 1e6 for sd in strategy_data]
    errs_hi = [(sd['ci_hi'] - sd['mean']) / 1e6 for sd in strategy_data]
    colors = ['#E74C3C'] + ['#27AE60'] * (len(strategy_data) - 1)

    y_pos = np.arange(len(names))
    bars = ax.barh(y_pos, means, xerr=[errs_lo, errs_hi], color=colors,
                   alpha=0.75, edgecolor='black', linewidth=0.5,
                   error_kw={'elinewidth': 1.5, 'capsize': 4, 'capthick': 1.5})

    # Reference line at cloud-only mean
    ax.axvline(x=cloud_mean / 1e6, color='#E74C3C', linestyle='--',
               linewidth=1.2, alpha=0.6, label='Cloud-only baseline')

    # Annotate each hybrid bar with its dominance percentage
    for i, sd in enumerate(strategy_data):
        if sd['percentile'] > 0:
            dominance = (cloud_mean - sd['mean']) / cloud_mean * 100
            ax.text(sd['mean'] / 1e6 + max(errs_hi) * 1.3, i,
                    f"-{dominance:.1f}% vs cloud", va='center', fontsize=10,
                    fontweight='bold', color='#1B5E20')

    ax.set_yticks(y_pos); ax.set_yticklabels(names)
    ax.invert_yaxis()
    ax.set_xlabel('Expected Total Cost over 36 Months ($M)', fontsize=12)
    ax.set_title('Strategy Comparison with Bootstrap 95% Confidence Intervals\n'
                 'Mid-Size Enterprise — Base Case ($\\mu$=30%, $\\sigma$=40%, '
                 'overhead=1.00)', fontsize=12)
    ax.grid(True, alpha=0.3, axis='x')
    ax.legend(loc='lower right', fontsize=10)
    ax.set_xlim(0, max(means) * 1.35)

    plt.tight_layout()
    plt.savefig('figure_a_strategy_comparison.png', dpi=150, bbox_inches='tight')
    plt.show()
    print(f"  Saved: figure_a_strategy_comparison.png")
    print(f"{'='*80}\n")


