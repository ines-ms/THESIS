                a = np.mean(d == 0) * 100
                m = np.mean(d == 1) * 100
                e = np.mean(d >= 2) * 100
                return f"{a:.0f}/{m:.0f}/{e:.0f}"
            re_dec = dec_str(r.decisions_reest)
            ss_dec = dec_str(r.decisions_subsim)
            pf_dec = dec_str(r.decisions_foresight)
            re_ov_s = f"{re_ov:.1f}%"
            ss_ov_s = f"{ss_ov:.1f}%"
            pf_ov_s = f"{pf_ov:.1f}%"
        else:
            re_dec = ss_dec = pf_dec = "—"
            re_ov_s = ss_ov_s = pf_ov_s = "—"

        print(f"  {r.name:<16} {r.n_gpus:>5} | "
              f"{fmt(nr_m):>9} {fmt(nr_cv):>10} | "
              f"{fmt(re_m):>9} {re_ov_s:>6} {re_dec:>6} | "
              f"{fmt(ss_m):>9} {ss_ov_s:>6} {ss_dec:>6} | "
              f"{fmt(pf_m):>9} {pf_ov_s:>6} {pf_dec:>6}")

    # Estimation quality — uses the SAME jump-aware estimator the firm uses
    print(f"\n  --- Parameter Estimation Quality at t=12 (jump-aware) ---")
    arch = archetype
    paths, jmask = generate_demand_paths(arch, seed=RANDOM_SEED, return_jumps=True)

    # Apply the same estimator the firm uses in the decision layers
    mu_hat_m, sigma_hat_m = estimate_params_jump_aware(paths, jmask)

    # Annualise for display
    mu_hat = mu_hat_m * 12                 # estimated annual log-drift (mu - sigma^2/2)
    sigma_hat = sigma_hat_m * np.sqrt(12)  # estimated annual sigma

    # Theoretical target: sample log-return mean estimates (mu - sigma^2/2)
    true_log_drift = arch.annual_drift - 0.5 * arch.annual_volatility**2
    implied_mu = mu_hat.mean() + 0.5 * (sigma_hat.mean())**2

    print(f"  True log-drift (mu-sigma^2/2)={true_log_drift:.3f} | "
          f"Est. mean={mu_hat.mean():.3f}, std={mu_hat.std():.3f}, "
          f"90%CI=[{np.percentile(mu_hat,5):.2f}, {np.percentile(mu_hat,95):.2f}]")
    print(f"  Implied annual drift (est + sigma^2/2)={implied_mu:.3f} "
          f"(True annual drift={arch.annual_drift:.2f})")
    print(f"  True sigma={arch.annual_volatility:.2f} | "
          f"Est. mean={sigma_hat.mean():.3f}, std={sigma_hat.std():.3f}")

    print(f"{'='*145}\n")


