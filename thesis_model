def plot_cost_composition():
    """
    FIGURE C: Cost composition stacked bar chart.

    Decomposes total cost by strategy under Framework A (cash-flow accounting):
      - Hardware capex (upfront, one-time at t=0)
      - Operating cost: power + overhead (monthly, while operating)
      - Cloud overflow (variable, above on-prem capacity)

    This is the mechanism figure: it explains *why* hybrid dominates by
    showing how the cost composition shifts from 100% variable (cloud-only)
    to a mix of upfront capex, ongoing opex, and overflow as commitment grows.
    """
    print(f"\n{'='*80}")
    print(f"  FIGURE C — Cost composition stacked bar chart")
    print(f"{'='*80}")

    arch = ARCHETYPES["midsize_enterprise"]
    paths, jmask = generate_demand_paths(arch, return_jumps=True)
    consts = compute_derived_constants()
    cloud_prices = cloud_price_schedule()

    # Per-GPU cost components under Framework A
    gpu_capex = consts['gpu_capex']                    # one-time at t=0
    monthly_opex = consts['monthly_opex_per_gpu']      # power + overhead, monthly

    strategies = []
    for pct in [0, 25, 50, 75, 90]:
        n_gpus = compute_onprem_sizing(arch, pct)
        cap_t = gpu_tokens_per_month_schedule()
        capacity_t = n_gpus * cap_t

        # Framework A decomposition (in $ over the full 36-month no-revision baseline)
        capex_total = n_gpus * gpu_capex
        opex_total = n_gpus * monthly_opex * T_MONTHS

        if n_gpus == 0:
            overflow_mean = (paths[:, 1:] * cloud_prices[np.newaxis, :]).sum(axis=1).mean()
        else:
            overflow = np.maximum(0, paths[:, 1:] - capacity_t[np.newaxis, :])
            overflow_mean = (overflow * cloud_prices[np.newaxis, :]).sum(axis=1).mean()

        name = "Cloud-Only (P0)" if pct == 0 else f"Hybrid P{pct}"
        strategies.append({
            'name': name,
            'capex': capex_total / 1e6,
            'opex': opex_total / 1e6,
            'cloud': overflow_mean / 1e6,
            'total': (capex_total + opex_total + overflow_mean) / 1e6,
        })

    # Plot
    fig, ax = plt.subplots(figsize=(11, 6))
    names = [s['name'] for s in strategies]
    capex_vals = [s['capex'] for s in strategies]
    opex_vals = [s['opex'] for s in strategies]
    cloud_vals = [s['cloud'] for s in strategies]
    x = np.arange(len(names))
    w = 0.6

    p1 = ax.bar(x, capex_vals, w, label='Hardware capex (upfront, t=0)',
                color='#1F4E79', edgecolor='black', linewidth=0.5)
    p2 = ax.bar(x, opex_vals, w, bottom=capex_vals,
                label='Operating cost: power + overhead (monthly)',
                color='#5B9BD5', edgecolor='black', linewidth=0.5)
    bottom_for_cloud = [c + o for c, o in zip(capex_vals, opex_vals)]
    p3 = ax.bar(x, cloud_vals, w, bottom=bottom_for_cloud,
                label='Cloud overflow (variable)',
                color='#E74C3C', edgecolor='black', linewidth=0.5, alpha=0.85)

    # Total cost annotation above each bar
    for i, s in enumerate(strategies):
        ax.text(i, s['total'] + 0.03, f"${s['total']:.2f}M",
                ha='center', fontsize=10, fontweight='bold')

    ax.set_xticks(x); ax.set_xticklabels(names, rotation=15, ha='right')
    ax.set_ylabel('Total Cost over 36 Months ($M)', fontsize=12)
    ax.set_title('Cost Composition by Strategy\n'
                 'Mid-Size Enterprise — Base Case '
                 '(overhead=1.00, cloud decline=20%/yr)', fontsize=12)
    ax.legend(fontsize=10, loc='upper left', bbox_to_anchor=(1.02, 1.0),
              borderaxespad=0, frameon=True)
    ax.grid(True, alpha=0.3, axis='y')
    ax.set_ylim(0, max(s['total'] for s in strategies) * 1.15)

    plt.tight_layout()
    plt.savefig('figure_c_cost_composition.png', dpi=150, bbox_inches='tight')
    plt.show()
    print(f"  Saved: figure_c_cost_composition.png")

    # Also print the underlying data for the thesis text
    print(f"\n  {'Strategy':<20} {'Capex':>10} {'Opex':>10} {'Cloud':>10} {'Total':>10}")
    print(f"  {'-'*62}")
    for s in strategies:
        print(f"  {s['name']:<20} ${s['capex']:>7.3f}M ${s['opex']:>7.3f}M "
              f"${s['cloud']:>7.3f}M ${s['total']:>7.3f}M")
    print(f"{'='*80}\n")


