def bootstrap_ci(n_boot=2000):
    """Bootstrap CIs on key metrics."""
    print(f"\n{'='*80}")
    print(f"  Bootstrap Confidence Intervals (B={n_boot})")
    print(f"{'='*80}")

    arch = ARCHETYPES["midsize_enterprise"]
    paths, jmask = generate_demand_paths(arch, n_sims=N_SIMULATIONS, seed=42, return_jumps=True)
    results = evaluate_all_strategies(paths, arch, jump_mask=jmask)

    rng = np.random.default_rng(99)

    print(f"  {'Strategy':<16} | {'Mean [95% CI]':^30} | {'OV [95% CI]':^24}")
    print(f"  {'-'*75}")

    for r in results:
        boot_means_nr = np.zeros(n_boot)
        boot_means_re = np.zeros(n_boot)

        for b in range(n_boot):
            idx = rng.choice(len(r.cost_no_revision), len(r.cost_no_revision), replace=True)
            boot_means_nr[b] = r.cost_no_revision[idx].mean()
            boot_means_re[b] = r.cost_reest[idx].mean()

        boot_ov = (boot_means_nr - boot_means_re) / boot_means_nr * 100

        nr_lo, nr_hi = np.percentile(boot_means_nr/1e6, [2.5, 97.5])
        re_lo, re_hi = np.percentile(boot_means_re/1e6, [2.5, 97.5])
        ov_lo, ov_hi = np.percentile(boot_ov, [2.5, 97.5])

        if r.percentile > 0:
            print(f"  {r.name:<16} | ${r.cost_reest.mean()/1e6:.3f}M "
                  f"[{re_lo:.3f}, {re_hi:.3f}] | "
                  f"{boot_ov.mean():.2f}% [{ov_lo:.2f}, {ov_hi:.2f}]")
        else:
            print(f"  {r.name:<16} | ${r.cost_no_revision.mean()/1e6:.3f}M "
                  f"[{nr_lo:.3f}, {nr_hi:.3f}] | —")

    print(f"{'='*80}\n")


