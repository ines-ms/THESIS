def sanity_check_demand():
    print(f"\n{'='*65}")
    print(f"  SANITY CHECK: sigma -> 0, no jumps -> deterministic growth")
    print(f"{'='*65}")
    det = FirmArchetype("Sanity Check", 2e9, 0.30, 0.001, 0.0, 0.0, 0.0,
                        "Near-zero volatility benchmark")
    paths = generate_demand_paths(det, n_sims=1000)
    expected = 2e9 * np.exp(0.30 * 3)
    actual = np.median(paths[:, -1])
    err = abs(actual - expected) / expected * 100
    print(f"  Expected (deterministic): {expected/1e9:.4f}B tokens/month")
    print(f"  Simulated median:         {actual/1e9:.4f}B tokens/month")
    print(f"  Error: {err:.4f}%")
    status = "PASS" if err < 1 else "FAIL"
    print(f"  {status} - convergence to deterministic TCO")
    print(f"{'='*65}\n")
    return err < 1


