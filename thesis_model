# FIGURE E: Monthly unit cost trajectory (mechanism figure)
# ============================================================================

def plot_unit_cost_trajectory():
    """
    FIGURE E: Monthly per-token cost trajectory for cloud and on-premises.

    Shows the underlying mechanism driving the abandonment-option dynamics:
    cloud price decline (20%/yr) closing the gap with on-premises effective
    unit cost (declining at 10%/yr through software optimisations).

    This is the mechanism figure: it explains *why* the firm faces a meaningful
    revision decision at t=12. The on-premises cost advantage is large at t=0
    but compresses over the horizon as cloud declines faster than on-prem.
    """
    print(f"\n{'='*80}")
    print(f"  FIGURE E — Monthly unit cost trajectory")
    print(f"{'='*80}")

    months = np.arange(T_MONTHS)

    # Cloud unit cost ($/M tokens) — exogenous deterministic decline
    cloud_unit = (CLOUD_PRICE_PER_M_TOKENS_START
                  * (CLOUD_PRICE_ANNUAL_RETENTION ** (1/12)) ** months)

    # On-prem effective unit cost — declines as throughput per GPU grows
    consts = compute_derived_constants()
    onprem_unit_t0 = consts['onprem_cost_per_m_tokens']
    capacity_t = gpu_tokens_per_month_schedule()
    capacity_t0 = capacity_t[0]
    onprem_unit = onprem_unit_t0 * (capacity_t0 / capacity_t)

    fig, ax = plt.subplots(figsize=(11, 6.5))
    ax.plot(months + 1, cloud_unit, '-', color='#E74C3C', linewidth=2.5,
            label=f'Cloud unit cost (${CLOUD_PRICE_PER_M_TOKENS_START:.2f}/M, '
                  f'declining 20%/yr)', zorder=4)
    ax.plot(months + 1, onprem_unit, '-', color='#1F4E79', linewidth=2.5,
            label=f'On-premises effective unit cost '
                  f'(${onprem_unit_t0:.2f}/M, declining 10%/yr)', zorder=5)
    ax.fill_between(months + 1, onprem_unit, cloud_unit,
                    where=(cloud_unit >= onprem_unit), alpha=0.12,
                    color='#1F4E79', label='On-prem unit cost advantage')

    # Mark t=12 review point
    ax.axvline(x=12, color='black', linestyle=':', linewidth=1.5, alpha=0.6,
               label='t=12 review point')

    # Annotate values at key months
    for m in [1, 12, 36]:
        c_val = cloud_unit[m-1]
        o_val = onprem_unit[m-1]
        ax.annotate(f'${c_val:.2f}', xy=(m, c_val),
                    xytext=(m, c_val + 0.3),
                    ha='center', fontsize=9, color='#C0392B', fontweight='bold')
        ax.annotate(f'${o_val:.2f}', xy=(m, o_val),
                    xytext=(m, o_val - 0.55),
                    ha='center', fontsize=9, color='#0D3866', fontweight='bold')

    ax.set_xlabel('Month', fontsize=12)
    ax.set_ylabel('Cost per Million Tokens ($/M)', fontsize=12)
    ax.set_title('Cloud and On-Premises Unit Cost Trajectories\n'
                 'On-premises retains a unit cost advantage across the horizon, '
                 'but the gap compresses as cloud declines faster',
                 fontsize=12)
    ax.legend(fontsize=10, loc='upper right')
    ax.grid(True, alpha=0.3)
    ax.set_xlim(0.5, 36.5)
    ax.set_ylim(0, max(cloud_unit.max(), onprem_unit.max()) * 1.18)

    plt.tight_layout()
    plt.savefig('figure_e_unit_cost_trajectory.png', dpi=150, bbox_inches='tight')
    plt.show()
    print(f"  Cloud at month 1:  ${cloud_unit[0]:.2f}/M")
    print(f"  Cloud at month 36: ${cloud_unit[-1]:.2f}/M  ({(1-cloud_unit[-1]/cloud_unit[0])*100:.1f}% decline)")
    print(f"  On-prem at month 1:  ${onprem_unit[0]:.2f}/M")
    print(f"  On-prem at month 36: ${onprem_unit[-1]:.2f}/M  ({(1-onprem_unit[-1]/onprem_unit[0])*100:.1f}% decline)")
    print(f"  Saved: figure_e_unit_cost_trajectory.png")
    print(f"{'='*80}\n")


