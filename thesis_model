# --- Strategy sizing ---
SIZING_PERCENTILES = [0, 25, 50, 75, 90]
SIZING_REFERENCE_MONTH = 18


# ============================================================================
# DERIVED CONSTANTS
# ============================================================================

def compute_derived_constants():
    """
    Compute per-GPU economic parameters under Framework A (cash-flow accounting).

    Capex is treated as a one-time outlay at acquisition (t=0 for original GPUs,
    t=12 for expansion GPUs). Monthly cost is opex only (power + overhead).
    Salvage is cash recovered at disposal.

    Overhead is calibrated as a multiple of (hardware-amortisation-equivalent + power),
    consistent with the literature convention. The hardware-amortisation reference
    is used only for overhead calibration, not as an actual monthly charge.

    Returned keys:
      gpu_tokens_per_month        : per-GPU effective throughput (tokens/month)
      monthly_opex_per_gpu        : ongoing monthly cost per operating GPU (power + overhead)
      gpu_capex                   : one-time hardware purchase cost per GPU
      onprem_cost_per_m_tokens    : levelised on-prem unit cost (informational; capex
                                    spread over asset life + opex, divided by throughput)
    """
    gpu_tokens_per_month = GPU_EFFECTIVE_TOKENS_PER_SEC * 86_400 * 30
    monthly_power = GPU_POWER_KW * PUE * 720 * ELECTRICITY_PRICE_KWH

    # Overhead calibrated against (hardware-amort-equivalent + power) per the
    # four-source literature convergence (Lenovo, Deloitte, SemiAnalysis, DevTk.AI).
    # The amortisation-equivalent ($GPU_PURCHASE_COST / GPU_DEPRECIATION_MONTHS) is
    # used only as the calibration reference; under Framework A the firm does not
    # actually pay this as a monthly charge.
    hardware_amort_reference = GPU_PURCHASE_COST / GPU_DEPRECIATION_MONTHS
    overhead = (hardware_amort_reference + monthly_power) * ONPREM_OVERHEAD_FRACTION

    monthly_opex = monthly_power + overhead

    # Levelised unit cost (informational, e.g. for the unit cost trajectory figure):
    # full lifecycle cost per GPU (capex + opex over asset life) divided by
    # full lifecycle throughput (asset life × monthly throughput).
    lifecycle_cost = GPU_PURCHASE_COST + monthly_opex * GPU_DEPRECIATION_MONTHS
    lifecycle_throughput = GPU_DEPRECIATION_MONTHS * gpu_tokens_per_month
    cost_per_m = lifecycle_cost / (lifecycle_throughput / 1e6)

    return {
        'gpu_tokens_per_month': gpu_tokens_per_month,
        'monthly_opex_per_gpu': monthly_opex,
        'gpu_capex': GPU_PURCHASE_COST,
        'onprem_cost_per_m_tokens': cost_per_m,
    }


# ============================================================================
# CLOUD PRICE SCHEDULE
# ============================================================================

def cloud_price_schedule(t_months=T_MONTHS, retention=CLOUD_PRICE_ANNUAL_RETENTION,
                         start_price=None):
    """Monthly cloud prices in $/token."""
    if start_price is None:
        start_price = CLOUD_PRICE_PER_M_TOKENS_START
    months = np.arange(t_months)
    monthly_ret = retention ** (1/12)
    return start_price * (monthly_ret ** months) / 1e6


def gpu_tokens_per_month_schedule(t_months=T_MONTHS, retention=ONPREM_DECLINE_RETENTION):
    """
    Monthly GPU effective token capacity, growing over time as software
    optimisations improve throughput on owned hardware.

    If retention=1.0, capacity is constant (original behaviour).
    If retention=0.90, effective cost per token falls 10%/year, equivalently
    capacity grows by 1/0.90 ~ 11.1% per year.

    Returns: array of length t_months with capacity at month t (t=0..t_months-1).
    Month 0 corresponds to the first cost month (i.e., demand_paths column 1).
    """
    base = GPU_EFFECTIVE_TOKENS_PER_SEC * 86_400 * 30
    months = np.arange(t_months)
    monthly_growth = (1.0 / retention) ** (1/12)
    return base * (monthly_growth ** months)


# ============================================================================
# ON-PREM SIZING
# ============================================================================

def compute_onprem_sizing(archetype, percentile, reference_month=SIZING_REFERENCE_MONTH):
    if percentile == 0:
        return 0
    consts = compute_derived_constants()
    mu_m = archetype.annual_drift / 12
    sigma_m = archetype.annual_volatility / np.sqrt(12)
    z = norm.ppf(percentile / 100)
    demand_pct = archetype.starting_tokens_per_month * np.exp(
        (mu_m - 0.5 * sigma_m**2) * reference_month +
        sigma_m * np.sqrt(reference_month) * z
    )
    return max(1, int(np.ceil(demand_pct / consts['gpu_tokens_per_month'])))


# ============================================================================
# PARAMETER ESTIMATION AT t=12
# ============================================================================
# The firm estimates drift and volatility from 12 months of observed demand,
# excluding months in which it knows discrete adoption events (jumps) occurred.
# This reflects the backward-looking knowledge that firms know when they
# launched major use cases. See Section 5 of the model logic document.
# ============================================================================

def estimate_params_jump_aware(demand_paths, jump_mask=None, min_clean=3):
    """
    Estimate mu_hat and sigma_hat from 12 months of observed demand,
    excluding months flagged as containing jumps.

    Parameters
    ----------
    demand_paths : array (n_sims, >= 13)
        Demand paths; only columns 0..12 are used.
    jump_mask : array (n_sims, >= 12) or None
        Boolean mask indicating which months contained jumps (True = jump).
        If None, uses all 12 observations (fallback behaviour).
    min_clean : int
        Minimum number of clean (non-jump) months required to use the
        jump-aware estimator. If fewer, falls back to using all observations.

    Returns
    -------
    mu_hat : array (n_sims,) — monthly drift estimate (on log scale)
    sigma_hat : array (n_sims,) — monthly volatility estimate (on log scale)
    """
    n_sims = demand_paths.shape[0]
    log_returns = np.diff(np.log(demand_paths[:, :13]), axis=1)  # (n_sims, 12)

    if jump_mask is None:
        # Fallback: no jump information, use all observations
        mu_hat = log_returns.mean(axis=1)
        sigma_hat = np.maximum(log_returns.std(axis=1, ddof=1), 0.001)
        return mu_hat, sigma_hat

    # Jump-aware estimation: use only months without jumps
    # Note: jump in month t means log-return for month t is contaminated
    # (because D(t) reflects the jump while D(t-1) does not).
    jump12 = jump_mask[:, :12]  # (n_sims, 12)
    clean_mask = ~jump12        # True where no jump

    mu_hat = np.zeros(n_sims)
    sigma_hat = np.zeros(n_sims)

    # Count clean months per sim
    n_clean = clean_mask.sum(axis=1)

    # Sims with enough clean months: use jump-aware estimator
    enough = n_clean >= min_clean
    # Sims with too few clean months: fall back to all observations
    too_few = ~enough

    # Vectorised handling: for each sim with enough clean months, compute
    # mean and std over clean subset. We loop because the subset differs per sim.
    for i in np.where(enough)[0]:
        clean_returns = log_returns[i, clean_mask[i]]
        mu_hat[i] = clean_returns.mean()
        sigma_hat[i] = max(clean_returns.std(ddof=1), 0.001)

    # Fallback for sims with too few clean months
    if too_few.any():
        idx = np.where(too_few)[0]
        mu_hat[idx] = log_returns[idx].mean(axis=1)
        sigma_hat[idx] = np.maximum(log_returns[idx].std(axis=1, ddof=1), 0.001)

    return mu_hat, sigma_hat


# ============================================================================
# LAYER 1: NO REVISION (Static baseline)
# ============================================================================

def compute_cost_no_revision(demand_paths, n_gpus, cloud_prices, consts,
                              onprem_retention=ONPREM_DECLINE_RETENTION):
    """36-month cost with fixed strategy, no revision.

    Framework A (cash-flow accounting):
      - Hardware capex paid upfront at t=0 (one-time)
      - Monthly opex (power + overhead) paid each month the GPU operates
      - Cloud overflow paid as variable cost above on-prem capacity

    onprem_retention controls the rate at which on-prem effective throughput
    grows (modelled as growing capacity per GPU). retention=1.0 = constant
    capacity (original behaviour); retention<1.0 = capacity grows over time.
    """
    n_sims = demand_paths.shape[0]
    if n_gpus == 0:
        return (demand_paths[:, 1:] * cloud_prices[np.newaxis, :]).sum(axis=1)

    gpu_cap_t = gpu_tokens_per_month_schedule(retention=onprem_retention)  # (T,)
    capacity_t = n_gpus * gpu_cap_t                                         # (T,)
    capex_upfront = n_gpus * consts['gpu_capex']
    opex_total = n_gpus * consts['monthly_opex_per_gpu'] * T_MONTHS
    overflow = np.maximum(0, demand_paths[:, 1:] - capacity_t[np.newaxis, :])
    cloud_cost = (overflow * cloud_prices[np.newaxis, :]).sum(axis=1)
    return capex_upfront + opex_total + cloud_cost


# ============================================================================
# LAYER 2: RE-ESTIMATION FORECAST REVISION (Primary method)
# ============================================================================

def compute_cost_reestimation_forecast(demand_paths, n_gpus, cloud_prices,
                                       consts, archetype, jump_mask=None,
                                       onprem_retention=ONPREM_DECLINE_RETENTION):
    """
    t=12 revision using parameter re-estimation from observed data.

    At t=12:
      1. Compute 12 monthly log-returns from observed demand
      2. Estimate drift (mu_hat) and volatility (sigma_hat) using
         jump-aware estimator (excludes months where firm knows jumps occurred)
      3. Project demand for months 13-36 using the MEAN forecast:
             E[D(12+k)] = D(12) * exp(mu_hat*k + 0.5*sigma_hat^2*k)
         This includes the Ito correction for lognormal mean vs median.
      4. Evaluate abandon/maintain/expand under projection
      5. Pick cheapest option
    Then actual demand plays out.

    onprem_retention controls on-prem effective throughput growth (capacity rises
    over time as software optimisations improve).
    """
    n_sims = demand_paths.shape[0]
    if n_gpus == 0:
        return (compute_cost_no_revision(demand_paths, 0, cloud_prices, consts,
                                          onprem_retention=onprem_retention),
                np.full(n_sims, -1, dtype=int))

    gpu_cap_t = gpu_tokens_per_month_schedule(retention=onprem_retention)  # (T,)
    gpu_cap = consts['gpu_tokens_per_month']  # base capacity (for sizing reference)
    cap_p1 = n_gpus * gpu_cap_t[:12]                # (12,) phase-1 capacity
    cap_p2 = n_gpus * gpu_cap_t[12:]                # (24,) phase-2 capacity (no expansion)
    delay = EXPANSION_DELAY_MONTHS

    monthly_opex = consts['monthly_opex_per_gpu']
    gpu_capex = consts['gpu_capex']

    # ---- Phase 1: Months 1-12 ----
    # Framework A: upfront capex at t=0 + monthly opex during operation + cloud overflow
    p1_capex = n_gpus * gpu_capex
    p1_opex = n_gpus * monthly_opex * 12
    overflow_p1 = np.maximum(0, demand_paths[:, 1:13] - cap_p1[np.newaxis, :])
    p1_cloud = (overflow_p1 * cloud_prices[:12][np.newaxis, :]).sum(axis=1)
    phase1 = p1_capex + p1_opex + p1_cloud

    # ---- Parameter re-estimation at t=12 (jump-aware) ----
    mu_hat, sigma_hat = estimate_params_jump_aware(demand_paths, jump_mask)

    # ---- Mean forecast: E[D(12+k)] = D(12) * exp(mu_hat*k + 0.5*sigma_hat^2*k) ----
    demand_at_12 = demand_paths[:, 12]
    projected = np.zeros((n_sims, 24))
    for k in range(24):
        k1 = k + 1
        projected[:, k] = demand_at_12 * np.exp(mu_hat * k1 + 0.5 * sigma_hat**2 * k1)

    cloud_p2 = cloud_prices[12:]
    salvage = n_gpus * gpu_capex * GPU_SALVAGE_FRACTION_AT_12

    # ---- Evaluate options under FORECAST (phase-2 forward costs only) ----
    # Note: original capex is sunk by t=12 and equal across all options, so it
    # does not enter the phase-2 comparison.

    # Option A: ABANDON — recover salvage cash, then pay cloud on full projected demand
    proj_abandon = (projected * cloud_p2[np.newaxis, :]).sum(axis=1) - salvage

    # Option B: MAINTAIN — pay opex on existing GPUs + cloud overflow
    proj_maintain_opex = n_gpus * monthly_opex * 24
    proj_maintain_overflow = np.maximum(0, projected - cap_p2[np.newaxis, :])
    proj_maintain = (proj_maintain_opex
                     + (proj_maintain_overflow * cloud_p2[np.newaxis, :]).sum(axis=1))

    # Option C: EXPAND — pay opex on existing + new GPUs + upfront capex on new + cloud overflow
    proj_demand_mid = projected[:, 11]  # Projected demand at month 24 (mean path)
    expand_targets = [
        demand_at_12,                    # Match current demand
        proj_demand_mid * 0.75,          # 75% of mid-horizon projection
        proj_demand_mid,                 # Full mid-horizon projection
    ]

    best_expand_proj = np.full(n_sims, np.inf)
    best_expand_idx = np.zeros(n_sims, dtype=int)

    for eidx, target in enumerate(expand_targets):
        n_target = np.maximum(np.ceil(target / gpu_cap).astype(int), n_gpus)
        n_new = n_target - n_gpus
        # Capacity after expansion: (n_target,) GPUs, time-varying throughput
        exp_cap_post = n_target[:, np.newaxis] * gpu_cap_t[12+delay:][np.newaxis, :]  # (n_sims, 24-delay)
        new_capex_upfront = n_new * gpu_capex  # one-time charge at t=12

        if delay > 0 and delay < 24:
            # Pre-delay: still on n_gpus, with phase-2 throughput (no new GPUs operating yet)
            pof_pre = np.maximum(0, projected[:, :delay] - cap_p2[:delay][np.newaxis, :])
            pc_pre = (pof_pre * cloud_p2[:delay][np.newaxis, :]).sum(axis=1)
            opex_pre = n_gpus * monthly_opex * delay

            # Post-delay: expanded GPUs operating
            pof_post = np.maximum(0, projected[:, delay:] - exp_cap_post)
            pc_post = (pof_post * cloud_p2[delay:][np.newaxis, :]).sum(axis=1)
            opex_post = (n_gpus + n_new) * monthly_opex * (24 - delay)

            proj_expand = opex_pre + pc_pre + opex_post + pc_post + new_capex_upfront
        else:
            exp_cap_full = n_target[:, np.newaxis] * gpu_cap_t[12:][np.newaxis, :]
            pof = np.maximum(0, projected - exp_cap_full)
            pc = (pof * cloud_p2[np.newaxis, :]).sum(axis=1)
            proj_expand = (n_gpus + n_new) * monthly_opex * 24 + pc + new_capex_upfront

        better = proj_expand < best_expand_proj
        best_expand_proj[better] = proj_expand[better]
        best_expand_idx[better] = eidx

    # ---- Decision: pick cheapest option under FORECAST ----
    all_proj = np.stack([proj_abandon, proj_maintain, best_expand_proj], axis=1)
    decisions = np.argmin(all_proj, axis=1)

    # ---- Apply decisions to ACTUAL demand ----
    actual_p2 = demand_paths[:, 13:]
    phase2 = np.zeros(n_sims)

    # Abandon — cloud on full actual demand minus salvage cash
    ma = decisions == 0
    if ma.any():
        phase2[ma] = (actual_p2[ma] * cloud_p2[np.newaxis, :]).sum(axis=1) - salvage

    # Maintain — opex on existing GPUs + cloud overflow on actual demand
    mm = decisions == 1
    if mm.any():
        m_opex = n_gpus * monthly_opex * 24
        mo = np.maximum(0, actual_p2[mm] - cap_p2[np.newaxis, :])
        phase2[mm] = m_opex + (mo * cloud_p2[np.newaxis, :]).sum(axis=1)

    # Expand — opex on existing + new + upfront new capex + cloud overflow
    me = decisions == 2
    if me.any():
        for eidx, target in enumerate(expand_targets):
            sub = me & (best_expand_idx == eidx)
            if not sub.any():
                continue
            nt = np.maximum(np.ceil(target[sub] / gpu_cap).astype(int), n_gpus)
            nn = nt - n_gpus
            new_capex_sub = nn * gpu_capex  # upfront capex per sim in this subset

            if delay > 0 and delay < 24:
                d_pre = actual_p2[sub, :delay]
                of_pre = np.maximum(0, d_pre - cap_p2[:delay][np.newaxis, :])
                c_pre = (of_pre * cloud_p2[:delay][np.newaxis, :]).sum(axis=1)
                opex_pre_sub = n_gpus * monthly_opex * delay
                d_post = actual_p2[sub, delay:]
                ec_post_sub = nt[:, np.newaxis] * gpu_cap_t[12+delay:][np.newaxis, :]
                of_post = np.maximum(0, d_post - ec_post_sub)
                c_post = (of_post * cloud_p2[delay:][np.newaxis, :]).sum(axis=1)
                opex_post_sub = (n_gpus + nn) * monthly_opex * (24 - delay)
                phase2[sub] = (opex_pre_sub + c_pre
                               + opex_post_sub + c_post + new_capex_sub)
            else:
                ec_full_sub = nt[:, np.newaxis] * gpu_cap_t[12:][np.newaxis, :]
                of_all = np.maximum(0, actual_p2[sub] - ec_full_sub)
                c_all = (of_all * cloud_p2[np.newaxis, :]).sum(axis=1)
                phase2[sub] = ((n_gpus + nn) * monthly_opex * 24
                               + c_all + new_capex_sub)

    return phase1 + phase2, decisions


# ============================================================================
# LAYER 2B: SUB-SIMULATION REVISION
# ============================================================================
# Replaces the mean-path (conditional expectation) forecast with a
# distributional forecast via sub-simulation, capturing the firm's own
# uncertainty about its parameter estimates at the t=12 decision point.
#
# Recommended by econometrics faculty as the methodologically rigorous
# approach for decision-analytic simulation under parameter uncertainty.
# ============================================================================

def compute_cost_sub_simulation(demand_paths, n_gpus, cloud_prices,
                                 consts, archetype,
                                 n_subpaths=200, chunk_size=500, seed=12345,
                                 jump_mask=None,
                                 onprem_retention=ONPREM_DECLINE_RETENTION):
    """
    t=12 revision using sub-simulation.

    At t=12, for each outer path:
      1. Estimate mu_hat, sigma_hat using jump-aware estimator
         (excludes months where firm knows jumps occurred)
      2. Generate n_subpaths GBM forecast paths for months 13-36
         using the firm's estimated parameters (no jumps — the firm
         acknowledges jumps can happen but cannot predict them)
      3. For each candidate action, compute the EXPECTED cost
         across the firm's forecast distribution
      4. Pick the action with the lowest expected cost
      5. Apply the decision to ACTUAL (true-DGP) demand

    Expansion targets are computed from the MEAN forecast:
        E[D(12+k)] = D(12) * exp(mu_hat*k + 0.5*sigma_hat^2*k)

    onprem_retention controls on-prem effective throughput growth.
    """
    n_sims = demand_paths.shape[0]
    if n_gpus == 0:
        return (compute_cost_no_revision(demand_paths, 0, cloud_prices, consts,
                                          onprem_retention=onprem_retention),
                np.full(n_sims, -1, dtype=int))

    gpu_cap_t = gpu_tokens_per_month_schedule(retention=onprem_retention)  # (T,)
    gpu_cap = consts['gpu_tokens_per_month']  # base value for sizing
    cap_p1 = n_gpus * gpu_cap_t[:12]
    cap_p2 = n_gpus * gpu_cap_t[12:]
    delay = EXPANSION_DELAY_MONTHS

    monthly_opex = consts['monthly_opex_per_gpu']
    gpu_capex = consts['gpu_capex']
    salvage = n_gpus * gpu_capex * GPU_SALVAGE_FRACTION_AT_12
    cloud_p2 = cloud_prices[12:]

    # ---- Phase 1: Months 1-12 (Framework A: upfront capex + monthly opex + cloud overflow) ----
    p1_capex = n_gpus * gpu_capex
    p1_opex = n_gpus * monthly_opex * 12
    overflow_p1 = np.maximum(0, demand_paths[:, 1:13] - cap_p1[np.newaxis, :])
    p1_cloud = (overflow_p1 * cloud_prices[:12][np.newaxis, :]).sum(axis=1)
    phase1 = p1_capex + p1_opex + p1_cloud

    # ---- Parameter re-estimation at t=12 (jump-aware) ----
    mu_hat, sigma_hat = estimate_params_jump_aware(demand_paths, jump_mask)
    demand_at_12 = demand_paths[:, 12]

    # Expansion targets from MEAN forecast (sizing is central-tendency;
    # sub-simulation affects action selection, not sizing magnitude)
    proj_mean_mid = demand_at_12 * np.exp(mu_hat * 12 + 0.5 * sigma_hat**2 * 12)

    # ---- Sub-simulation: firm's forecast distribution ----
    rng = np.random.default_rng(seed)

    exp_abandon = np.zeros(n_sims)
    exp_maintain = np.zeros(n_sims)
    best_exp_expand = np.full(n_sims, np.inf)
    best_expand_idx = np.zeros(n_sims, dtype=int)

    # Phase-2 capacity broadcasts for sub-simulation: shape (1, 1, 24)
    cap_p2_b = cap_p2[np.newaxis, np.newaxis, :]
    cap_p2_pre_b = cap_p2[:delay][np.newaxis, np.newaxis, :]   # (1, 1, delay)

    for chunk_start in range(0, n_sims, chunk_size):
        chunk_end = min(chunk_start + chunk_size, n_sims)
        cs = slice(chunk_start, chunk_end)
        n_chunk = chunk_end - chunk_start

        mu_c = mu_hat[cs, np.newaxis, np.newaxis]
        sig_c = sigma_hat[cs, np.newaxis, np.newaxis]
        d12_c = demand_at_12[cs, np.newaxis, np.newaxis]

        # Generate GBM forecast paths
        Z = rng.standard_normal((n_chunk, n_subpaths, 24))
        log_incr = (mu_c - 0.5 * sig_c**2) + sig_c * Z
        log_cum = np.cumsum(log_incr, axis=2)
        sub_paths = d12_c * np.exp(log_cum)  # (n_chunk, n_subpaths, 24)

        cp2 = cloud_p2[np.newaxis, np.newaxis, :]

        # Option A: ABANDON — recover salvage cash, then pay cloud on full forecast
        cost_abandon = (sub_paths * cp2).sum(axis=2) - salvage
        exp_abandon[cs] = cost_abandon.mean(axis=1)

        # Option B: MAINTAIN — opex on existing GPUs + cloud overflow
        of_maintain = np.maximum(0, sub_paths - cap_p2_b)
        opex_maintain = n_gpus * monthly_opex * 24
        cost_maintain = opex_maintain + (of_maintain * cp2).sum(axis=2)
        exp_maintain[cs] = cost_maintain.mean(axis=1)

        # Option C: EXPAND (multiple targets, pick best expected cost)
        proj_mid_c = proj_mean_mid[cs]
        expand_targets_c = [
            demand_at_12[cs],
            proj_mid_c * 0.75,
            proj_mid_c,
        ]

        best_exp_chunk = np.full(n_chunk, np.inf)
        best_idx_chunk = np.zeros(n_chunk, dtype=int)

        for eidx, target in enumerate(expand_targets_c):
            n_target = np.maximum(np.ceil(target / gpu_cap).astype(int), n_gpus)
            n_new = n_target - n_gpus
            new_capex_upfront = n_new * gpu_capex  # one-time at t=12

            if delay > 0 and delay < 24:
                # Pre-delay: still on n_gpus, with phase-2 throughput
                pre = sub_paths[:, :, :delay]
                of_pre = np.maximum(0, pre - cap_p2_pre_b)
                c_pre = (of_pre * cp2[:, :, :delay]).sum(axis=2)
                opex_pre = n_gpus * monthly_opex * delay
                # Post-delay: expanded GPUs, with phase-2-post throughput
                exp_cap_post = (n_target[:, np.newaxis, np.newaxis] *
                                gpu_cap_t[12+delay:][np.newaxis, np.newaxis, :])  # (n_chunk, 1, 24-delay)
                post = sub_paths[:, :, delay:]
                of_post = np.maximum(0, post - exp_cap_post)
                c_post = (of_post * cp2[:, :, delay:]).sum(axis=2)
                opex_post = ((n_gpus + n_new) * monthly_opex * (24 - delay))[:, np.newaxis]
                cost_expand = (opex_pre + c_pre + opex_post + c_post
                               + new_capex_upfront[:, np.newaxis])
            else:
                exp_cap_full = (n_target[:, np.newaxis, np.newaxis] *
                                gpu_cap_t[12:][np.newaxis, np.newaxis, :])
                of_all = np.maximum(0, sub_paths - exp_cap_full)
                c_all = (of_all * cp2).sum(axis=2)
                opex_all = ((n_gpus + n_new) * monthly_opex * 24)[:, np.newaxis]
                cost_expand = opex_all + c_all + new_capex_upfront[:, np.newaxis]

            exp_expand_avg = cost_expand.mean(axis=1)

            better = exp_expand_avg < best_exp_chunk
            best_exp_chunk[better] = exp_expand_avg[better]
            best_idx_chunk[better] = eidx

        best_exp_expand[cs] = best_exp_chunk
        best_expand_idx[cs] = best_idx_chunk

        del sub_paths, log_incr, log_cum, Z

    # ---- Decision: lowest expected cost under firm's beliefs ----
    all_exp = np.stack([exp_abandon, exp_maintain, best_exp_expand], axis=1)
    decisions = np.argmin(all_exp, axis=1)

    # ---- Apply decisions to ACTUAL demand (true DGP) ----
    actual_p2 = demand_paths[:, 13:]
    phase2 = np.zeros(n_sims)

    # Abandon — cloud on full actual demand minus salvage
    ma = decisions == 0
    if ma.any():
        phase2[ma] = (actual_p2[ma] * cloud_p2[np.newaxis, :]).sum(axis=1) - salvage

    # Maintain — opex on existing + cloud overflow
    mm = decisions == 1
    if mm.any():
        m_opex = n_gpus * monthly_opex * 24
        mo = np.maximum(0, actual_p2[mm] - cap_p2[np.newaxis, :])
        phase2[mm] = m_opex + (mo * cloud_p2[np.newaxis, :]).sum(axis=1)

    # Expand — reconstruct chosen target per sim
    me = decisions == 2
    if me.any():
        expand_targets_full = [
            demand_at_12,
            proj_mean_mid * 0.75,
            proj_mean_mid,
        ]
        for eidx, target in enumerate(expand_targets_full):
            sub = me & (best_expand_idx == eidx)
            if not sub.any():
                continue
            nt = np.maximum(np.ceil(target[sub] / gpu_cap).astype(int), n_gpus)
            nn = nt - n_gpus
            new_capex_sub = nn * gpu_capex

            if delay > 0 and delay < 24:
                d_pre = actual_p2[sub, :delay]
                of_pre = np.maximum(0, d_pre - cap_p2[:delay][np.newaxis, :])
                c_pre = (of_pre * cloud_p2[:delay][np.newaxis, :]).sum(axis=1)
                opex_pre_sub = n_gpus * monthly_opex * delay
                d_post = actual_p2[sub, delay:]
                ec_post_sub = nt[:, np.newaxis] * gpu_cap_t[12+delay:][np.newaxis, :]
                of_post = np.maximum(0, d_post - ec_post_sub)
                c_post = (of_post * cloud_p2[delay:][np.newaxis, :]).sum(axis=1)
                opex_post_sub = (n_gpus + nn) * monthly_opex * (24 - delay)
                phase2[sub] = (opex_pre_sub + c_pre
                               + opex_post_sub + c_post + new_capex_sub)
            else:
                ec_full_sub = nt[:, np.newaxis] * gpu_cap_t[12:][np.newaxis, :]
                of_all = np.maximum(0, actual_p2[sub] - ec_full_sub)
                c_all = (of_all * cloud_p2[np.newaxis, :]).sum(axis=1)
                phase2[sub] = ((n_gpus + nn) * monthly_opex * 24
                               + c_all + new_capex_sub)

    return phase1 + phase2, decisions


# ============================================================================
# LAYER 3: PERFECT FORESIGHT REVISION (Upper bound)
# ============================================================================

def compute_cost_perfect_foresight(demand_paths, n_gpus, cloud_prices,
                                    consts, archetype,
                                    onprem_retention=ONPREM_DECLINE_RETENTION):
    """
    t=12 revision using actual future demand (months 13-36).
    This is unachievable in practice — provides theoretical upper bound
    on option value.

    onprem_retention controls on-prem effective throughput growth.
    """
    n_sims = demand_paths.shape[0]
    if n_gpus == 0:
        return (compute_cost_no_revision(demand_paths, 0, cloud_prices, consts,
                                          onprem_retention=onprem_retention),
                np.full(n_sims, -1, dtype=int))

    gpu_cap_t = gpu_tokens_per_month_schedule(retention=onprem_retention)
    gpu_cap = consts['gpu_tokens_per_month']  # base value for sizing
    cap_p1 = n_gpus * gpu_cap_t[:12]
    cap_p2 = n_gpus * gpu_cap_t[12:]
    delay = EXPANSION_DELAY_MONTHS

    monthly_opex = consts['monthly_opex_per_gpu']
    gpu_capex = consts['gpu_capex']

    # Phase 1 (Framework A: upfront capex + monthly opex + cloud overflow)
    p1_capex = n_gpus * gpu_capex
    p1_opex = n_gpus * monthly_opex * 12
    overflow_p1 = np.maximum(0, demand_paths[:, 1:13] - cap_p1[np.newaxis, :])
    p1_cloud = (overflow_p1 * cloud_prices[:12][np.newaxis, :]).sum(axis=1)
    phase1 = p1_capex + p1_opex + p1_cloud

    # Phase 2 — use ACTUAL demand for evaluation
    actual_p2 = demand_paths[:, 13:]
    cloud_p2 = cloud_prices[12:]
    demand_at_12 = demand_paths[:, 12]
    salvage = n_gpus * gpu_capex * GPU_SALVAGE_FRACTION_AT_12

    # Abandon — recover salvage cash, then pay cloud on full actual demand
    cost_abandon = (actual_p2 * cloud_p2[np.newaxis, :]).sum(axis=1) - salvage

    # Maintain — opex on existing GPUs + cloud overflow on actual demand
    cost_maintain = (n_gpus * monthly_opex * 24 +
                     (np.maximum(0, actual_p2 - cap_p2[np.newaxis, :]) * cloud_p2[np.newaxis, :]).sum(axis=1))

    # Expand (multiple targets) — opex on existing + new + upfront new capex + cloud overflow
    expand_targets = [demand_at_12, demand_at_12 * 1.5, demand_at_12 * 2.0]
    best_expand = np.full(n_sims, np.inf)

    for target in expand_targets:
        nt = np.maximum(np.ceil(target / gpu_cap).astype(int), n_gpus)
        nn = nt - n_gpus
        new_capex_upfront = nn * gpu_capex

        if delay > 0 and delay < 24:
            of_pre = np.maximum(0, actual_p2[:, :delay] - cap_p2[:delay][np.newaxis, :])
            c_pre = (of_pre * cloud_p2[:delay][np.newaxis, :]).sum(axis=1)
            opex_pre = n_gpus * monthly_opex * delay
            ec_post = nt[:, np.newaxis] * gpu_cap_t[12+delay:][np.newaxis, :]
            of_post = np.maximum(0, actual_p2[:, delay:] - ec_post)
            c_post = (of_post * cloud_p2[delay:][np.newaxis, :]).sum(axis=1)
            opex_post = (n_gpus + nn) * monthly_opex * (24 - delay)
            cost_exp = opex_pre + c_pre + opex_post + c_post + new_capex_upfront
        else:
            ec_full = nt[:, np.newaxis] * gpu_cap_t[12:][np.newaxis, :]
            of_all = np.maximum(0, actual_p2 - ec_full)
            c_all = (of_all * cloud_p2[np.newaxis, :]).sum(axis=1)
            cost_exp = (n_gpus + nn) * monthly_opex * 24 + c_all + new_capex_upfront

        best_expand = np.minimum(best_expand, cost_exp)

    all_opts = np.stack([cost_abandon, cost_maintain, best_expand], axis=1)
    decisions = np.argmin(all_opts, axis=1)
    best_phase2 = all_opts[np.arange(n_sims), decisions]

    return phase1 + best_phase2, decisions


# ============================================================================
# STRATEGY RESULT & EVALUATION
# ============================================================================

@dataclass
class StrategyResult:
    name: str
    percentile: int
    n_gpus: int
    capacity: float
    cost_no_revision: np.ndarray
    cost_reest: np.ndarray
    cost_subsim: np.ndarray
    cost_foresight: np.ndarray
    decisions_reest: np.ndarray
    decisions_subsim: np.ndarray
    decisions_foresight: np.ndarray


def compute_cvar(costs, alpha=0.95):
    threshold = np.percentile(costs, alpha * 100)
    return costs[costs >= threshold].mean()


def evaluate_all_strategies(demand_paths, archetype,
                            cloud_retention=CLOUD_PRICE_ANNUAL_RETENTION,
                            onprem_retention=ONPREM_DECLINE_RETENTION,
                            run_subsim=True, n_subpaths=200,
                            jump_mask=None):
    """Evaluate all strategies with all methods (no rev / forecast / subsim / foresight).

    If jump_mask is provided (shape (n_sims, t_months)), the firm uses
    jump-aware parameter estimation excluding known jump months.

    cloud_retention: annual retention factor for cloud price (0.80 = 20% decline)
    onprem_retention: annual retention factor for on-prem effective cost
                      (0.90 = 10% decline; 1.00 = no decline / original behaviour)
    """
    consts = compute_derived_constants()
    cloud_prices = cloud_price_schedule(retention=cloud_retention)
    results = []

    for pct in SIZING_PERCENTILES:
        n_gpus = compute_onprem_sizing(archetype, pct)
        cap = n_gpus * consts['gpu_tokens_per_month']

        c_nr = compute_cost_no_revision(demand_paths, n_gpus, cloud_prices, consts,
                                         onprem_retention=onprem_retention)
        c_re, d_re = compute_cost_reestimation_forecast(
            demand_paths, n_gpus, cloud_prices, consts, archetype,
            jump_mask=jump_mask, onprem_retention=onprem_retention)
        if run_subsim:
            c_ss, d_ss = compute_cost_sub_simulation(
                demand_paths, n_gpus, cloud_prices, consts, archetype,
                n_subpaths=n_subpaths, jump_mask=jump_mask,
                onprem_retention=onprem_retention)
        else:
            c_ss = c_re.copy()
            d_ss = d_re.copy()
        c_pf, d_pf = compute_cost_perfect_foresight(
            demand_paths, n_gpus, cloud_prices, consts, archetype,
            onprem_retention=onprem_retention)

        name = "Cloud-Only (P0)" if pct == 0 else f"Hybrid P{pct}"
        results.append(StrategyResult(
            name=name, percentile=pct, n_gpus=n_gpus, capacity=cap,
            cost_no_revision=c_nr, cost_reest=c_re,
            cost_subsim=c_ss, cost_foresight=c_pf,
            decisions_reest=d_re, decisions_subsim=d_ss,
            decisions_foresight=d_pf
        ))

    return results


