# DIAGONAL SENSITIVITY: CLOUD x ON-PREM DECLINE RATES
# ============================================================================

def diagonal_sensitivity(n_sims=5000):
    """
    Three-scenario diagonal sensitivity for cloud and on-prem decline rates.

    Conservative: cloud 10% / on-prem 0%   (slow AI cost progress)
    Base case:    cloud 20% / on-prem 10%  (literature midpoint)
    Optimistic:   cloud 30% / on-prem 20%  (historical pace continues)

    The diagonal (rather than full grid) reflects that cloud and on-prem
    decline rates depend on the same underlying technology trends and are
    therefore correlated in practice.

    Citations:
      - Cloud rate: Appenzeller (a16z, 2024); Gundlach et al. (2025)
      - On-prem rate: Gundlach et al. (2025), arXiv:2511.23455
        (algorithmic efficiency progress ~3x/year, attenuated for
         enterprise deployment lag and excluding hardware generation jumps)
    """
    print(f"\n{'='*80}")
    print(f"  DIAGONAL SENSITIVITY — Cloud x On-Prem Decline Rates (n={n_sims})")
    print(f"{'='*80}")

    arch = ARCHETYPES["midsize_enterprise"]
    paths, jmask = generate_demand_paths(arch, n_sims=n_sims, seed=42, return_jumps=True)

    scenarios = [
        ("Conservative", 0.90, 1.00),  # cloud 10%, on-prem 0%
        ("Base case",    0.80, 0.90),  # cloud 20%, on-prem 10%
        ("Optimistic",   0.70, 0.80),  # cloud 30%, on-prem 20%
    ]

    print(f"  {'Scenario':<14} | {'Cloud':>6} {'On-prem':>8} | "
          f"{'Best NR':>8} {'NR Cost':>10} | "
          f"{'Best RE':>8} {'RE Cost':>10} {'OV':>7}")
    print(f"  {'-'*82}")

    all_results = {}
    for name, cloud_ret, onprem_ret in scenarios:
        results = evaluate_all_strategies(
            paths, arch,
            cloud_retention=cloud_ret,
            onprem_retention=onprem_ret,
            run_subsim=False,
            jump_mask=jmask)

        # Find best strategy under no-revision and re-estimation forecast
        best_nr_cost = np.inf
        best_nr_pct = 0
        best_re_cost = np.inf
        best_re_pct = 0
        best_ov = 0.0

        for r in results:
            nr_m = r.cost_no_revision.mean()
            re_m = r.cost_reest.mean()
            if nr_m < best_nr_cost:
                best_nr_cost = nr_m
                best_nr_pct = r.percentile
            if re_m < best_re_cost:
                best_re_cost = re_m
                best_re_pct = r.percentile
                # OV computed against no-revision cost at the same sizing
                best_ov = (r.cost_no_revision.mean() - re_m) / r.cost_no_revision.mean() * 100

        cloud_decline = (1 - cloud_ret) * 100
        op_decline = (1 - onprem_ret) * 100
        print(f"  {name:<14} | {cloud_decline:>5.0f}% {op_decline:>7.0f}% | "
              f"P{best_nr_pct:>5} ${best_nr_cost/1e6:>7.3f}M | "
              f"P{best_re_pct:>5} ${best_re_cost/1e6:>7.3f}M {best_ov:>5.2f}%")

        all_results[name] = {
            'cloud_retention': cloud_ret,
            'onprem_retention': onprem_ret,
            'best_nr_pct': best_nr_pct,
            'best_nr_cost': best_nr_cost,
            'best_re_pct': best_re_pct,
            'best_re_cost': best_re_cost,
            'option_value': best_ov,
            'results': results,
        }

    print(f"\n  Robustness check across the diagonal:")
    sizing_robust = len(set(r['best_nr_pct'] for r in all_results.values())) == 1
    print(f"    Optimal sizing percentile constant across scenarios: {sizing_robust}")
    if not sizing_robust:
        sizings = {n: r['best_nr_pct'] for n, r in all_results.items()}
        print(f"    Sizings by scenario: {sizings}")
    ovs = [r['option_value'] for r in all_results.values()]
    print(f"    Option value range: {min(ovs):.2f}% – {max(ovs):.2f}%")
    print(f"{'='*80}\n")

    return all_results


# ============================================================================
# OVERHEAD SENSITIVITY CHECK
# ============================================================================
# Robustness check for the headline findings against the on-premises overhead
# parameter. The base case uses ONPREM_OVERHEAD_FRACTION = 1.00, the midpoint
# of the four-source literature convergence range (0.84-1.25). This function
# re-runs the mid-size enterprise base case at the lower bound (0.85, anchored
# to Lenovo and Deloitte) and the upper bound (1.25, anchored to DevTk.AI) to
# verify that the directional findings (hybrid dominance, optimal sizing,
# H4 monotonicity sign) hold across the literature range. Output is a small
# comparison table suitable for the robustness section of the thesis.
# ============================================================================

def overhead_sensitivity_check():
    """
    Sensitivity of headline findings to ONPREM_OVERHEAD_FRACTION.

    Re-runs the mid-size enterprise base case at three overhead values
    spanning the literature convergence range:
        0.85 - lower (Lenovo 2026: 0.84; Deloitte 2026: 0.89)
        1.00 - midpoint, base case (anchored to SemiAnalysis ~1.00)
        1.25 - upper (DevTk.AI 2026)

    For each value, reports: on-prem unit cost, cloud baseline cost,
    best hybrid cost, optimal sizing percentile, and hybrid dominance.
    Returns a list of dicts and prints a comparison table plus a
    directional verdict on whether findings are robust.
    """
    global ONPREM_OVERHEAD_FRACTION
    original_overhead = ONPREM_OVERHEAD_FRACTION

    print(f"\n{'='*80}")
    print(f"  OVERHEAD SENSITIVITY — Robustness across literature range")
    print(f"{'='*80}")
    print(f"  Re-running mid-size enterprise base case at three overhead values")
    print(f"  to verify that directional findings hold across the convergence")
    print(f"  range identified in the literature (0.84-1.25 across four sources).")
    print(f"{'='*80}")

    overhead_values = [
        (0.85, "Lower (Lenovo, Deloitte)"),
        (1.00, "Midpoint (base case)"),
        (1.25, "Upper (DevTk.AI)"),
    ]

    arch = ARCHETYPES["midsize_enterprise"]
    rows = []

    for ov_val, ov_label in overhead_values:
        # Override the global, then re-derive constants and re-run.
        # Same seed each iteration so the comparison is clean.
        ONPREM_OVERHEAD_FRACTION = ov_val
        consts = compute_derived_constants()

        paths, jmask = generate_demand_paths(arch, return_jumps=True)
        results = evaluate_all_strategies(paths, arch, jump_mask=jmask)

        # Extract headline numbers
        cloud_result = next(r for r in results if r.percentile == 0)
        cloud_cost = cloud_result.cost_no_revision.mean()

        hybrid_costs = {
            r.percentile: r.cost_reest.mean()
            for r in results if r.percentile > 0
        }
        best_pct = min(hybrid_costs, key=hybrid_costs.get)
        best_cost = hybrid_costs[best_pct]
        dominance_pct = (cloud_cost - best_cost) / cloud_cost * 100

        rows.append({
            'overhead': ov_val,
            'label': ov_label,
            'unit_cost': consts['onprem_cost_per_m_tokens'],
            'cloud_cost': cloud_cost,
            'best_pct': best_pct,
            'best_cost': best_cost,
            'dominance_pct': dominance_pct,
        })

    # Restore the original value so anything downstream is unaffected
    ONPREM_OVERHEAD_FRACTION = original_overhead

    # Print comparison table
    print(f"\n  {'Overhead':>9} | {'$/1M tok':>9} | {'Cloud TCO':>10} | "
          f"{'Best Hybrid':>12} | {'Best P':>7} | {'Dominance':>10}")
    print(f"  {'-'*72}")
    for r in rows:
