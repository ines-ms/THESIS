def gpu_throughput_sensitivity():
    """Test how effective inference throughput affects unit costs and strategy choice.

    Note: 'effective inference throughput' bundles hardware capability, model
    choice, inference engine (vLLM, TensorRT-LLM), batching strategy, and
    quantization. It is not a pure hardware specification.
    """
    print(f"\n{'='*80}")
    print(f"  Effective Inference Throughput Sensitivity Analysis")
    print(f"  (bundles hardware + model + inference engine + batching + quantization)")
    print(f"{'='*80}")

    throughputs = [75, 100, 150, 200, 250, 300]
    arch = ARCHETYPES["midsize_enterprise"]
    paths, jmask = generate_demand_paths(arch, n_sims=5000, seed=42, return_jumps=True)

    print(f"  {'Eff. tput':>10} | {'$/1M tok':>8} | {'vs Cloud':>10} | "
          f"{'Best NR':>8} | {'Best RE':>8} | {'RE OV':>8}")
    print(f"  {'-'*65}")

    for tps in throughputs:
        # Recompute constants with different throughput, under Framework A
        gpu_cap = tps * 86400 * 30
        # Overhead calibrated against (hw-amort-equivalent + power) per literature
        # convention (Lenovo, Deloitte, SemiAnalysis, DevTk.AI). The amortisation
        # equivalent is used only for overhead calibration, not as a monthly charge.
        hw_amort_reference = GPU_PURCHASE_COST / GPU_DEPRECIATION_MONTHS
        power = GPU_POWER_KW * PUE * 720 * ELECTRICITY_PRICE_KWH
        overhead = (hw_amort_reference + power) * ONPREM_OVERHEAD_FRACTION
        monthly_opex = power + overhead

        # Levelised unit cost (informational): full lifecycle / full throughput
        lifecycle_cost = GPU_PURCHASE_COST + monthly_opex * GPU_DEPRECIATION_MONTHS
        lifecycle_throughput = GPU_DEPRECIATION_MONTHS * gpu_cap
        cost_per_m = lifecycle_cost / (lifecycle_throughput / 1e6)

        consts = {
            'gpu_tokens_per_month': gpu_cap,
            'monthly_opex_per_gpu': monthly_opex,
            'gpu_capex': GPU_PURCHASE_COST,
            'onprem_cost_per_m_tokens': cost_per_m,
        }
        cloud_prices = cloud_price_schedule()

        best_nr_cost = np.inf
        best_re_cost = np.inf
        best_nr_pct = 0
        best_re_pct = 0
        best_ov = 0

        for pct in SIZING_PERCENTILES:
            if pct == 0:
                n_gpus = 0
            else:
                from scipy.stats import norm as norm_dist
                mu_m = arch.annual_drift / 12
                sigma_m = arch.annual_volatility / np.sqrt(12)
                z = norm_dist.ppf(pct / 100)
                demand_pct = arch.starting_tokens_per_month * np.exp(
                    (mu_m - 0.5 * sigma_m**2) * 18 + sigma_m * np.sqrt(18) * z)
                n_gpus = max(1, int(np.ceil(demand_pct / gpu_cap)))

            c_nr = compute_cost_no_revision(paths, n_gpus, cloud_prices, consts)
            c_re, _ = compute_cost_reestimation_forecast(
                paths, n_gpus, cloud_prices, consts, arch, jump_mask=jmask)

            if c_nr.mean() < best_nr_cost:
                best_nr_cost = c_nr.mean()
                best_nr_pct = pct
            if c_re.mean() < best_re_cost:
                best_re_cost = c_re.mean()
                best_re_pct = pct
                best_ov = (c_nr.mean() - c_re.mean()) / c_nr.mean() * 100

        vs_cloud = "CHEAPER" if cost_per_m < CLOUD_PRICE_PER_M_TOKENS_START else "PRICIER"
        print(f"  {tps:>7} t/s | ${cost_per_m:>6.2f} | {vs_cloud:>10} | "
              f"P{best_nr_pct:>5} | P{best_re_pct:>5} | {best_ov:>6.2f}%")

    print(f"\n  Effective inference throughput is the most influential single parameter.")
    print(f"  A 4x range (75-300 tok/s) creates a 4x unit cost range.")
    print(f"  This range bundles hardware, software stack, and quantization choices.")
    print(f"{'='*80}\n")


