# H2: BREAK-EVEN SHIFT UNDER UNCERTAINTY
# ============================================================================

def revision_value_at_threshold(n_sims=5000):
    """Informational test: revision option value across starting demand levels.

    NOTE: This function is NOT the H2 test. It compares hybrid P50 with
    re-estimation revision against hybrid P50 without revision, both run
    under the full stochastic process. The crossover difference between
    the two curves measures the value of the revision option at the
    margin between cloud and on-prem dominance — not the variance-driven
    threshold shift that H2 isolates.

    The proper H2 test (deterministic vs stochastic, both no-revision)
    is implemented in `breakeven_h2()` below.
    """
    print(f"\n{'='*80}")
    print(f"  Revision Value at Break-Even Threshold (informational)")
    print(f"{'='*80}")

    consts = compute_derived_constants()
    cloud_prices = cloud_price_schedule()

    # Sweep starting demand to find where on-prem becomes cheaper.
    # Range chosen to bracket the expected stochastic crossover and the
    # base case (S0 = 2B tokens/month) at the current cost stack
    # (overhead = 1.00, on-prem unit cost ~$4.79/M). At 30%/year drift,
    # demand grows ~2.3x over 36 months, so a starting demand of even
    # 0.3-0.5B/month already produces time-averaged demand high enough
    # for on-prem to dominate. The sweep starts at 0.05B/month (well
    # below where on-prem could win) and runs to 2.5B/month (above the
    # base case starting demand) to capture both the deterministic and
    # stochastic crossover points and to bracket the base case.
    starts = np.linspace(0.05e9, 2.5e9, 40)
    base = ARCHETYPES["midsize_enterprise"]

    det_crossover = None
    stoch_crossover = None

    # Collect full data series for plotting
    cloud_costs = []
    nr_costs = []
    cf_costs = []

    print(f"  {'Start (B/mo)':>12} | {'Cloud Mean':>10} | {'P50 NR':>10} | "
          f"{'P50 CF':>10} | {'Winner NR':>10}")
    print(f"  {'-'*65}")

    for d0 in starts:
        arch = FirmArchetype("sweep", d0, base.annual_drift, base.annual_volatility,
                              base.jump_frequency, base.jump_mean, base.jump_std, "")
        paths, jmask = generate_demand_paths(arch, n_sims=n_sims, seed=42, return_jumps=True)

        n_gpus_50 = compute_onprem_sizing(arch, 50)
        c_cloud = compute_cost_no_revision(paths, 0, cloud_prices, consts)
        c_p50_nr = compute_cost_no_revision(paths, n_gpus_50, cloud_prices, consts)
        c_p50_cf, _ = compute_cost_reestimation_forecast(
            paths, n_gpus_50, cloud_prices, consts, arch, jump_mask=jmask)

        cloud_costs.append(c_cloud.mean())
        nr_costs.append(c_p50_nr.mean())
        cf_costs.append(c_p50_cf.mean())

        winner = "ON-PREM" if c_p50_nr.mean() < c_cloud.mean() else "CLOUD"

        if c_p50_nr.mean() < c_cloud.mean() and det_crossover is None:
            det_crossover = d0
        if c_p50_cf.mean() < c_cloud.mean() and stoch_crossover is None:
            stoch_crossover = d0

        if d0 in [starts[0], starts[len(starts)//4], starts[len(starts)//2],
                  starts[3*len(starts)//4], starts[-1]]:
            print(f"  {d0/1e9:>10.1f}B | ${c_cloud.mean()/1e6:>8.3f}M | "
                  f"${c_p50_nr.mean()/1e6:>8.3f}M | ${c_p50_cf.mean()/1e6:>8.3f}M | "
                  f"{winner:>10}")

    print(f"\n  Crossover demand level (best hybrid cheaper than cloud):")
    if det_crossover:
        print(f"    No revision strategy:        ~{det_crossover/1e9:.2f}B tokens/month start")
    if stoch_crossover:
        print(f"    Re-estimation forecast:      ~{stoch_crossover/1e9:.2f}B tokens/month start")

    if det_crossover and stoch_crossover:
        shift = (stoch_crossover - det_crossover) / det_crossover * 100
        print(f"    Revision shifts crossover by {shift:+.1f}% relative to no-revision")

    # ---- Generate H2 break-even plot ----
    starts_b = np.array(starts) / 1e9
    cloud_arr = np.array(cloud_costs) / 1e6
    nr_arr = np.array(nr_costs) / 1e6
    cf_arr = np.array(cf_costs) / 1e6

    fig, ax = plt.subplots(figsize=(11, 6.5))
    ax.plot(starts_b, cloud_arr, '-', color='#E74C3C', linewidth=2.5,
            label='Cloud-only (P0)', zorder=3)
    ax.plot(starts_b, nr_arr, '-o', color='#1F4E79', linewidth=2, markersize=4,
            label='Hybrid P50, no revision', zorder=4)
    ax.plot(starts_b, cf_arr, '-s', color='#2E7D32', linewidth=2, markersize=4,
            label='Hybrid P50, with re-estimation forecast', zorder=5)

    # Mark crossover points
    if det_crossover is not None:
        ax.axvline(x=det_crossover/1e9, color='#1F4E79', linestyle='--',
                   linewidth=1.5, alpha=0.7,
                   label=f'No-revision crossover (~{det_crossover/1e9:.2f}B)')
    if stoch_crossover is not None:
        ax.axvline(x=stoch_crossover/1e9, color='#2E7D32', linestyle='--',
                   linewidth=1.5, alpha=0.7,
                   label=f'Re-estimation crossover (~{stoch_crossover/1e9:.2f}B)')

    # Mark base case
    ax.axvline(x=2.0, color='black', linestyle=':', linewidth=1.5, alpha=0.5,
               label='Base case (S₀ = 2.0B)')

    ax.set_xlabel('Starting Demand S₀ (Billions of tokens/month)', fontsize=12)
    ax.set_ylabel('Expected Total Cost over 36 Months ($M)', fontsize=12)
    ax.set_title('Revision Option Value at the Break-Even Threshold\n'
                 'Comparison of P50 hybrid cost with and without revision option, both stochastic',
                 fontsize=12)
    ax.legend(fontsize=9, loc='upper left')
    ax.grid(True, alpha=0.3)
    ax.set_xlim(0, 2.55)

    plt.tight_layout()
    plt.savefig('figure_revision_value_at_threshold.png', dpi=150, bbox_inches='tight')
    plt.show()
    print(f"  Saved: figure_revision_value_at_threshold.png")
    print(f"{'='*80}\n")


# ============================================================================
# H2: VARIANCE-DRIVEN THRESHOLD SHIFT (Dixit-Pindyck irreversibility test)
# ============================================================================

def breakeven_h2(n_sims=5000):
    """
    H2 — Variance-driven threshold shift under demand uncertainty.

    Compares the on-premises break-even threshold under two regimes:
      - Deterministic: σ ≈ 0, no jumps. Demand follows the expected path
        exactly. This represents the no-uncertainty benchmark.
      - Stochastic: full base-case parameters (σ = 0.40, jumps as specified).
        Demand realises around its expected path with volatility and jumps.

    Both regimes use no-revision strategies, so the t=12 revision option is
    disabled. This isolates the variance-driven threshold effect that H2
    predicts, separately from the option value mechanisms tested in H3 and H4.

    To ensure both regimes share the same expected-demand trajectory, the
    deterministic regime's drift is adjusted upward to include the jump
    compensator. Under the Merton jump-diffusion specification:
        E[D(t)] = D(0) × exp[(μ + λ × (E[J] - 1)) × t]
    where E[J] = exp(jump_mean + 0.5 × jump_std²) is the expected jump
    multiplier. The deterministic-regime drift is therefore set to
    μ_det = μ + λ × (E[J] - 1), which equals approximately 0.635/year at
    base case (vs. the nominal stochastic drift parameter of 0.30/year).
    Without this adjustment, the deterministic regime would have a lower
    expected demand path than the stochastic regime, conflating the
    variance effect with a path-level effect.

    H2 (Dixit-Pindyck): the stochastic crossover should occur at higher
    starting demand than the deterministic crossover, reflecting the
    irreversibility premium that uncertainty places on infrastructure
    commitment.
    """
    print(f"\n{'='*80}")
    print(f"  H2 — Variance-Driven Threshold Shift (Dixit-Pindyck irreversibility test)")
    print(f"{'='*80}")

    consts = compute_derived_constants()
    cloud_prices = cloud_price_schedule()
    base = ARCHETYPES["midsize_enterprise"]

    # ---- Compute jump compensator to align expected demand paths ----
    # E[J] - 1 where J = exp(N(jump_mean, jump_std^2))
    expected_jump_multiplier_minus_1 = (np.exp(base.jump_mean + 0.5 * base.jump_std**2) - 1)
    # Compound expected drift: nominal drift + λ × (E[J] - 1)
    mu_det = base.annual_drift + base.jump_frequency * expected_jump_multiplier_minus_1

    print(f"  Comparing no-revision break-even thresholds in two regimes:")
    print(f"    Deterministic: σ ≈ 0, no jumps, μ_det = {mu_det:.4f}/yr (drift + jump compensator)")
    print(f"    Stochastic:    σ = {base.annual_volatility:.2f}, jumps at λ = {base.jump_frequency}/yr,")
    print(f"                   μ = {base.annual_drift:.2f}/yr (nominal drift)")
    print(f"  Drift adjustment ensures both regimes share the same E[D(t)] trajectory,")
    print(f"  isolating the variance effect that H2 predicts.")
    print(f"{'='*80}")

    # Sweep starting demand. Same range as the informational revision-value
    # test for direct comparability.
    starts = np.linspace(0.05e9, 2.5e9, 40)

    det_crossover = None
    stoch_crossover = None

    det_best_costs = []
    stoch_best_costs = []
    cloud_costs_det = []
    cloud_costs_stoch = []
    det_best_pcts = []
    stoch_best_pcts = []

    print(f"  {'Start (B/mo)':>12} | {'Det Cloud':>10} | {'Det Best':>10} | "
          f"{'Stoch Cloud':>11} | {'Stoch Best':>11}")
    print(f"  {'-'*70}")

    for d0 in starts:
        # ---- Deterministic regime (drift adjusted to match stochastic E[D]) ----
        det_arch = FirmArchetype(
            "det", d0, mu_det, 0.001,  # σ ≈ 0 for numerical stability
            0.0, 0.0, 0.0, "Deterministic regime (matched expected path)"
        )
        det_paths = generate_demand_paths(det_arch, n_sims=n_sims, seed=42)

        # ---- Stochastic regime (base case parameters) ----
        stoch_arch = FirmArchetype(
            "stoch", d0, base.annual_drift, base.annual_volatility,
            base.jump_frequency, base.jump_mean, base.jump_std, "Stochastic regime"
        )
        stoch_paths = generate_demand_paths(stoch_arch, n_sims=n_sims, seed=42)

        # For each regime: compute cloud-only cost and best hybrid no-revision cost.
        det_cloud_cost = compute_cost_no_revision(det_paths, 0, cloud_prices, consts).mean()
        stoch_cloud_cost = compute_cost_no_revision(stoch_paths, 0, cloud_prices, consts).mean()

        det_best_cost = np.inf
        stoch_best_cost = np.inf
        det_best_pct = 0
        stoch_best_pct = 0

        for pct in [25, 50, 75, 90]:
            n_gpus_det = compute_onprem_sizing(det_arch, pct)
            n_gpus_stoch = compute_onprem_sizing(stoch_arch, pct)

            c_det = compute_cost_no_revision(det_paths, n_gpus_det, cloud_prices, consts).mean()
            c_stoch = compute_cost_no_revision(stoch_paths, n_gpus_stoch, cloud_prices, consts).mean()

            if c_det < det_best_cost:
                det_best_cost = c_det
                det_best_pct = pct
            if c_stoch < stoch_best_cost:
                stoch_best_cost = c_stoch
                stoch_best_pct = pct

        cloud_costs_det.append(det_cloud_cost)
        cloud_costs_stoch.append(stoch_cloud_cost)
        det_best_costs.append(det_best_cost)
        stoch_best_costs.append(stoch_best_cost)
        det_best_pcts.append(det_best_pct)
        stoch_best_pcts.append(stoch_best_pct)

        # Crossover: first starting demand at which best hybrid beats cloud-only
        if det_best_cost < det_cloud_cost and det_crossover is None:
            det_crossover = d0
        if stoch_best_cost < stoch_cloud_cost and stoch_crossover is None:
            stoch_crossover = d0

        if d0 in [starts[0], starts[len(starts)//4], starts[len(starts)//2],
                  starts[3*len(starts)//4], starts[-1]]:
            print(f"  {d0/1e9:>10.2f}B | ${det_cloud_cost/1e6:>8.3f}M | "
                  f"${det_best_cost/1e6:>8.3f}M | "
                  f"${stoch_cloud_cost/1e6:>9.3f}M | ${stoch_best_cost/1e6:>9.3f}M")

    print(f"\n  Break-even crossover (best hybrid cheaper than cloud-only):")
    if det_crossover is not None:
        print(f"    Deterministic regime: ~{det_crossover/1e9:.2f}B tokens/month start")
    if stoch_crossover is not None:
        print(f"    Stochastic regime:    ~{stoch_crossover/1e9:.2f}B tokens/month start")

    if det_crossover is not None and stoch_crossover is not None:
        shift_pct = (stoch_crossover - det_crossover) / det_crossover * 100
        print(f"\n  Threshold shift: {shift_pct:+.1f}% (stochastic relative to deterministic)")
        if stoch_crossover > det_crossover:
            print(f"  H2 SUPPORTED: variance raises the on-premises investment threshold")
        elif stoch_crossover < det_crossover:
            print(f"  H2 NOT SUPPORTED: variance lowers the threshold (contrary to Dixit-Pindyck)")
        else:
            print(f"  H2 INCONCLUSIVE: thresholds coincide at the sweep resolution")

    # ---- Generate H2 plot ----
    starts_b = np.array(starts) / 1e9
    det_cloud_arr = np.array(cloud_costs_det) / 1e6
    stoch_cloud_arr = np.array(cloud_costs_stoch) / 1e6
    det_best_arr = np.array(det_best_costs) / 1e6
    stoch_best_arr = np.array(stoch_best_costs) / 1e6

    fig, ax = plt.subplots(figsize=(11, 6.5))

    # Deterministic regime: cloud (lighter) and best hybrid
    ax.plot(starts_b, det_cloud_arr, '-', color='#E74C3C', linewidth=2,
            alpha=0.5, label='Deterministic: cloud-only', zorder=2)
    ax.plot(starts_b, det_best_arr, '-o', color='#1F4E79', linewidth=2,
            markersize=4, alpha=0.7, label='Deterministic: best hybrid (no revision)', zorder=3)

    # Stochastic regime: cloud and best hybrid
    ax.plot(starts_b, stoch_cloud_arr, '-', color='#C0392B', linewidth=2.5,
            label='Stochastic: cloud-only', zorder=4)
    ax.plot(starts_b, stoch_best_arr, '-s', color='#0D3866', linewidth=2.5,
            markersize=4, label='Stochastic: best hybrid (no revision)', zorder=5)

    # Crossover markers
    if det_crossover is not None:
        ax.axvline(x=det_crossover/1e9, color='#1F4E79', linestyle='--',
                   linewidth=1.5, alpha=0.6,
                   label=f'Deterministic crossover (~{det_crossover/1e9:.2f}B)')
    if stoch_crossover is not None:
        ax.axvline(x=stoch_crossover/1e9, color='#0D3866', linestyle='--',
                   linewidth=1.5, alpha=0.8,
                   label=f'Stochastic crossover (~{stoch_crossover/1e9:.2f}B)')

    # Base case
    ax.axvline(x=2.0, color='black', linestyle=':', linewidth=1.5, alpha=0.5,
               label='Base case (S₀ = 2.0B)')

    ax.set_xlabel('Starting Demand S₀ (Billions of tokens/month)', fontsize=12)
    ax.set_ylabel('Expected Total Cost over 36 Months ($M)', fontsize=12)
    ax.set_title('H2: Variance-Driven Break-Even Threshold Shift\n'
                 'Deterministic vs. Stochastic Regimes at Matched Expected Demand Paths',
                 fontsize=12)
    ax.legend(fontsize=9, loc='upper left')
    ax.grid(True, alpha=0.3)
    ax.set_xlim(0, 2.55)

    plt.tight_layout()
    plt.savefig('figure_h2_variance_threshold.png', dpi=150, bbox_inches='tight')
    plt.show()
    print(f"  Saved: figure_h2_variance_threshold.png")
    print(f"{'='*80}\n")


