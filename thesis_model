def sweep_price_decline(n_sims=5000):
    """Option value decomposition across price decline rates."""
    print(f"\n{'='*80}")
    print(f"  H4 — Option Value vs Cloud Price Decline (n={n_sims})")
    print(f"{'='*80}")

    arch = ARCHETYPES["midsize_enterprise"]
    paths, jmask = generate_demand_paths(arch, n_sims=n_sims, seed=42, return_jumps=True)
    consts = compute_derived_constants()

    retentions = [0.60, 0.70, 0.75, 0.80, 0.85, 0.90, 0.95]
    pct_test = 50  # Test P50

    ov_re_list = []
    ov_pf_list = []

    print(f"  {'Decline':>8} | {'NR Mean':>10} | {'RE Mean':>10} {'RE OV':>7} | "
          f"{'PF Mean':>10} {'PF OV':>7} | {'Captured':>9}")
    print(f"  {'-'*75}")

    for ret in retentions:
        cp = cloud_price_schedule(retention=ret)
        n_gpus = compute_onprem_sizing(arch, pct_test)

        c_nr = compute_cost_no_revision(paths, n_gpus, cp, consts)
        c_re, _ = compute_cost_reestimation_forecast(paths, n_gpus, cp, consts, arch, jump_mask=jmask)
        c_pf, _ = compute_cost_perfect_foresight(paths, n_gpus, cp, consts, arch)

        nr_m = c_nr.mean()
        re_ov = (nr_m - c_re.mean()) / nr_m * 100
        pf_ov = (nr_m - c_pf.mean()) / nr_m * 100
        captured = re_ov / max(pf_ov, 0.001) * 100

        ov_re_list.append(re_ov)
        ov_pf_list.append(pf_ov)

        decline = (1-ret)*100
        print(f"  {decline:>6.0f}%  | ${nr_m/1e6:>8.3f}M | ${c_re.mean()/1e6:>8.3f}M {re_ov:>6.2f}% | "
              f"${c_pf.mean()/1e6:>8.3f}M {pf_ov:>6.2f}% | {captured:>7.1f}%")

    # Plot — reverse data so x-axis goes ascending (5% to 40%) for intuitive reading
    # Single-panel design: show the two option-value curves and the information gap.
    # The "% captured" right panel was removed because the metric breaks down at low
    # decline rates where the re-estimation forecast generates losses while perfect
    # foresight remains positive (negative-divided-by-positive produces uninterpretable
    # negative percentages).
    fig, ax1 = plt.subplots(1, 1, figsize=(10, 6.5))
    # Reverse all sequences so the slowest decline is on the left
    retentions_plot = list(reversed(retentions))
    ov_re_plot = list(reversed(ov_re_list))
    ov_pf_plot = list(reversed(ov_pf_list))
    x = range(len(retentions_plot))
    x_labels = [f"{(1-r)*100:.0f}%" for r in retentions_plot]

    # Find index of base case (20% decline = retention 0.80) for the reference line
    base_case_decline = 20.0
    base_case_idx = None
    for k, r in enumerate(retentions_plot):
        if abs((1-r)*100 - base_case_decline) < 0.5:
            base_case_idx = k
            break

    ax1.plot(x, ov_re_plot, '-o', color='#2196F3', linewidth=2.5, markersize=7,
             label='Re-estimation forecast (primary)')
    ax1.plot(x, ov_pf_plot, '--s', color='#F44336', linewidth=2, markersize=6,
             alpha=0.7, label='Perfect foresight (upper bound)')
    ax1.fill_between(x, ov_re_plot, ov_pf_plot, alpha=0.1, color='grey',
                      label='Information gap')
    ax1.axhline(y=0, color='grey', linestyle='-', linewidth=0.5)
    if base_case_idx is not None:
        ax1.axvline(x=base_case_idx, color='black', linestyle=':', linewidth=1.5,
                    alpha=0.6, label='Base case (20%/yr)')
    ax1.set_xticks(x); ax1.set_xticklabels(x_labels)
    ax1.set_xlabel('Annual Cloud Price Decline Rate', fontsize=12)
    ax1.set_ylabel('Option Value (% of no-revision cost)', fontsize=12)
    ax1.set_title('H4: Option Value vs Cloud Price Decline\n(Hybrid P50, Mid-Size Enterprise)')
    ax1.legend(fontsize=10, loc='upper left'); ax1.grid(True, alpha=0.3)

    plt.tight_layout()
    plt.savefig('h4_price_decline.png', dpi=150, bbox_inches='tight')
    plt.show()

    print(f"{'='*80}\n")


