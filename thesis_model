# SALVAGE VALUE SENSITIVITY
# ============================================================================
# Tests whether the directional findings (hybrid dominance, option value,
# abandon/maintain/expand split) are robust to the salvage assumption.
# Base case: 70% (GPULoans, 2026). Range: 50% (pessimistic) to 80% (optimistic).
# ============================================================================

def salvage_sensitivity(n_sims=5000):
    """
    Sensitivity of headline findings to GPU_SALVAGE_FRACTION_AT_12.

    Re-runs the mid-size enterprise base case at three salvage values:
        0.50 - pessimistic (below all available market evidence)
        0.70 - base case (conservative end of GPULoans 2026 estimate)
        0.80 - optimistic (upper end of GPULoans 2026 estimate)

    For each value, reports: best strategy, option value, and
    abandon/maintain/expand decision split under re-estimation forecast.
    """
    global GPU_SALVAGE_FRACTION_AT_12
    original_salvage = GPU_SALVAGE_FRACTION_AT_12

    print(f"\n{'='*80}")
    print(f"  SALVAGE VALUE SENSITIVITY — Robustness across plausible range")
    print(f"{'='*80}")
    print(f"  Re-running mid-size enterprise base case at three salvage values")
    print(f"  to verify that directional findings hold.")
    print(f"{'='*80}")

    salvage_values = [
        (0.50, "Pessimistic"),
        (0.70, "Base case (GPULoans 2026)"),
        (0.80, "Optimistic"),
    ]

    arch = ARCHETYPES["midsize_enterprise"]
    consts = compute_derived_constants()
    rows = []

    for sv, label in salvage_values:
        GPU_SALVAGE_FRACTION_AT_12 = sv
        paths, jmask = generate_demand_paths(arch, n_sims=n_sims, seed=42,
                                              return_jumps=True)
        results = evaluate_all_strategies(paths, arch, run_subsim=False,
                                          jump_mask=jmask)

        # Extract headline numbers
        cloud_result = next(r for r in results if r.percentile == 0)
        cloud_cost = cloud_result.cost_no_revision.mean()

        best_pct = 0
        best_cost = np.inf
        best_ov = 0.0
        best_dec_split = ""

        for r in results:
            if r.percentile == 0:
                continue
            re_cost = r.cost_reest.mean()
            if re_cost < best_cost:
                best_cost = re_cost
                best_pct = r.percentile
                nr_cost = r.cost_no_revision.mean()
                best_ov = (nr_cost - re_cost) / nr_cost * 100
                a = np.mean(r.decisions_reest == 0) * 100
                m = np.mean(r.decisions_reest == 1) * 100
                e = np.mean(r.decisions_reest >= 2) * 100
                best_dec_split = f"{a:.0f}/{m:.0f}/{e:.0f}"

        dominance = (cloud_cost - best_cost) / cloud_cost * 100

        rows.append({
            'salvage': sv,
            'label': label,
            'cloud_cost': cloud_cost,
            'best_pct': best_pct,
            'best_cost': best_cost,
            'dominance': dominance,
            'option_value': best_ov,
            'decision_split': best_dec_split,
        })

    # Restore original
    GPU_SALVAGE_FRACTION_AT_12 = original_salvage

    # Print comparison table
    print(f"\n  {'Salvage':>9} | {'Cloud TCO':>10} | {'Best Hybrid':>12} | "
          f"{'Best P':>7} | {'Dominance':>10} | {'OV':>7} | {'A/M/E':>8}")
    print(f"  {'-'*78}")
    for r in rows:
        print(f"  {r['salvage']:>8.0%} | ${r['cloud_cost']/1e6:>7.3f}M | "
              f"${r['best_cost']/1e6:>9.3f}M | "
              f"P{r['best_pct']:>5} | {r['dominance']:>8.1f}% | "
              f"{r['option_value']:>5.2f}% | {r['decision_split']:>8}")

    # Robustness verdict
    all_hybrid_wins = all(r['dominance'] > 0 for r in rows)
    print(f"\n  Robustness verdict:")
    if all_hybrid_wins:
        print(f"    Hybrid dominates pure cloud at ALL three salvage values")
        print(f"    Dominance range: {min(r['dominance'] for r in rows):.1f}% "
              f"to {max(r['dominance'] for r in rows):.1f}%")
        print(f"    Option value range: {min(r['option_value'] for r in rows):.2f}% "
              f"to {max(r['option_value'] for r in rows):.2f}%")
        print(f"    => Directional findings ROBUST across salvage range")
    else:
        print(f"    => Discuss boundary cases in robustness section")
    print(f"{'='*80}\n")

    return rows


