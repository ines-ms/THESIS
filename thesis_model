def plot_action_mix(n_sims=10_000):
    """
    FIGURE F: Action mix at t=12 across hybrid sizing strategies.

    Shows the proportion of paths exercising abandon, maintain, or expand
    under the re-estimation forecast revision. Visualises the 100/0/0
    finding at base case parameters that motivates the Trigeorgis (1993,
    1996) abandonment-option reframing.
    """
    print(f"\n{'='*80}")
    print(f"  FIGURE F — Action mix at t=12 across hybrid strategies")
    print(f"{'='*80}")

    arch = ARCHETYPES["midsize_enterprise"]
    paths, jmask = generate_demand_paths(arch, n_sims=n_sims, seed=42, return_jumps=True)
    results = evaluate_all_strategies(paths, arch, run_subsim=False, jump_mask=jmask)

    hybrid_results = [r for r in results if r.percentile > 0]

    abandon_pcts = []
    maintain_pcts = []
    expand_pcts = []
    names = []

    for r in hybrid_results:
        a = np.mean(r.decisions_reest == 0) * 100
        m = np.mean(r.decisions_reest == 1) * 100
        e = np.mean(r.decisions_reest >= 2) * 100
        abandon_pcts.append(a)
        maintain_pcts.append(m)
        expand_pcts.append(e)
        names.append(f"P{r.percentile}")

    fig, ax = plt.subplots(figsize=(10, 6))
    x = np.arange(len(names))
    w = 0.65

    p1 = ax.bar(x, abandon_pcts, w, label='Abandon (exit on-prem, recover salvage)',
                color='#E74C3C', edgecolor='black', linewidth=0.5)
    p2 = ax.bar(x, maintain_pcts, w, bottom=abandon_pcts,
                label='Maintain (continue on-prem unchanged)',
                color='#3498DB', edgecolor='black', linewidth=0.5)
    bottom_e = [a + m for a, m in zip(abandon_pcts, maintain_pcts)]
    p3 = ax.bar(x, expand_pcts, w, bottom=bottom_e,
                label='Expand (add capacity)',
                color='#27AE60', edgecolor='black', linewidth=0.5)

    # Annotate the abandon percentage on each bar
    for i, a in enumerate(abandon_pcts):
        if a > 5:
            ax.text(i, a / 2, f'{a:.0f}%', ha='center', va='center',
                    color='white', fontweight='bold', fontsize=12)

    ax.set_xticks(x); ax.set_xticklabels(names)
    ax.set_xlabel('Initial Sizing Percentile', fontsize=12)
    ax.set_ylabel('Share of Simulation Paths (%)', fontsize=12)
    ax.set_title('Optimal Action at t=12 Under Re-estimation Forecast\n'
                 f'Mid-Size Enterprise — Base Case (n={n_sims:,} paths)',
                 fontsize=12)
    ax.legend(fontsize=10, loc='upper left', bbox_to_anchor=(1.02, 1.0),
              borderaxespad=0, frameon=True)
    ax.grid(True, alpha=0.3, axis='y')
    ax.set_ylim(0, 105)

    plt.tight_layout()
    plt.savefig('figure_f_action_mix.png', dpi=150, bbox_inches='tight')
    plt.show()
    print(f"  Action mix (abandon / maintain / expand) by sizing:")
    for n, a, m, e in zip(names, abandon_pcts, maintain_pcts, expand_pcts):
        print(f"    {n}: {a:.0f}% / {m:.0f}% / {e:.0f}%")
    print(f"  Saved: figure_f_action_mix.png")
    print(f"{'='*80}\n")


