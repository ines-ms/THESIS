def heatmap_mu_sigma(n_sims=3000):
    """Sweep drift and volatility, find best strategy and option value."""
    print(f"\n{'='*80}")
    print(f"  H1/H2/H3 — Strategy Heatmap: mu x sigma (n={n_sims})")
    print(f"{'='*80}")

    base = ARCHETYPES["midsize_enterprise"]
    mus = [0.10, 0.20, 0.30, 0.40, 0.50, 0.60]
    sigmas = [0.05, 0.10, 0.20, 0.30, 0.40, 0.50, 0.60, 0.70]

    consts = compute_derived_constants()
    cloud_prices = cloud_price_schedule()

    best_nr = np.zeros((len(mus), len(sigmas)))       # Best pctile, no revision
    best_re = np.zeros((len(mus), len(sigmas)))       # Best pctile, with forecast
    ov_grid = np.zeros((len(mus), len(sigmas)))        # Option value at best NR
    cvar_reduce = np.zeros((len(mus), len(sigmas)))   # CVaR reduction
    dominance_grid = np.zeros((len(mus), len(sigmas))) # Hybrid dominance over cloud-only

    for i, mu in enumerate(mus):
        for j, sig in enumerate(sigmas):
            arch = FirmArchetype(
                f"sweep_{mu}_{sig}", base.starting_tokens_per_month,
                mu, sig, base.jump_frequency, base.jump_mean, base.jump_std, "")
            paths, jmask = generate_demand_paths(arch, n_sims=n_sims, seed=42+i*100+j, return_jumps=True)

            best_nr_cost = np.inf
            best_re_cost = np.inf
            best_nr_pct = 0
            best_re_pct = 0
            best_ov = 0
            best_cvar_r = 0
            cloud_only_cost = None

            for pct in SIZING_PERCENTILES:
                n_gpus = compute_onprem_sizing(arch, pct)
                c_nr = compute_cost_no_revision(paths, n_gpus, cloud_prices, consts)
                c_re, _ = compute_cost_reestimation_forecast(
                    paths, n_gpus, cloud_prices, consts, arch, jump_mask=jmask)

                if pct == 0:
                    cloud_only_cost = c_nr.mean()

                if c_nr.mean() < best_nr_cost:
                    best_nr_cost = c_nr.mean()
                    best_nr_pct = pct
                    ov = (c_nr.mean() - c_re.mean()) / c_nr.mean() * 100
                    best_ov = ov
                    cvar_nr = compute_cvar(c_nr)
                    cvar_re = compute_cvar(c_re)
                    best_cvar_r = (cvar_nr - cvar_re) / cvar_nr * 100

                if c_re.mean() < best_re_cost:
                    best_re_cost = c_re.mean()
                    best_re_pct = pct

            best_nr[i, j] = best_nr_pct
            best_re[i, j] = best_re_pct
            ov_grid[i, j] = best_ov
            cvar_reduce[i, j] = best_cvar_r
            # Hybrid dominance: % savings of best hybrid (CF) vs pure cloud-only
            if cloud_only_cost is not None and cloud_only_cost > 0:
                dominance_grid[i, j] = (cloud_only_cost - best_re_cost) / cloud_only_cost * 100

    # Plot
    fig, axes = plt.subplots(1, 3, figsize=(22, 7))
    sig_labels = [f"{s:.0%}" for s in sigmas]
    mu_labels = [f"{m:.0%}" for m in mus]

    # Hybrid dominance over cloud-only — replaces the flat best-sizing panel
    # which was visually monotone (P25 across most of the grid)
    ax1 = axes[0]
    im1 = ax1.imshow(dominance_grid, cmap='Greens', aspect='auto', origin='lower',
                     vmin=0)
    ax1.set_xticks(range(len(sigmas))); ax1.set_xticklabels(sig_labels)
    ax1.set_yticks(range(len(mus))); ax1.set_yticklabels(mu_labels)
    ax1.set_xlabel('Volatility (σ)'); ax1.set_ylabel('Drift (μ)')
    ax1.set_title('Hybrid Dominance over Cloud-Only\n(% cost reduction)')
    for ii in range(len(mus)):
        for jj in range(len(sigmas)):
            ax1.text(jj, ii, f"{dominance_grid[ii,jj]:.1f}%",
                     ha='center', va='center', fontsize=8)
    plt.colorbar(im1, ax=ax1, label='Cost reduction %')

    # Option value
    ax2 = axes[1]
    im2 = ax2.imshow(ov_grid, cmap='Blues', aspect='auto', origin='lower')
    ax2.set_xticks(range(len(sigmas))); ax2.set_xticklabels(sig_labels)
    ax2.set_yticks(range(len(mus))); ax2.set_yticklabels(mu_labels)
    ax2.set_xlabel('Volatility (σ)'); ax2.set_ylabel('Drift (μ)')
    ax2.set_title('Re-estimation Forecast\nOption Value (%)')
    for ii in range(len(mus)):
        for jj in range(len(sigmas)):
            ax2.text(jj, ii, f"{ov_grid[ii,jj]:.1f}%", ha='center', va='center', fontsize=7)
    plt.colorbar(im2, ax=ax2, label='Option Value %')

    # Best strategy shift (NR vs CF)
    ax3 = axes[2]
    shift = best_re - best_nr
    im3 = ax3.imshow(shift, cmap='RdBu_r', aspect='auto', origin='lower',
                      vmin=-40, vmax=40)
    ax3.set_xticks(range(len(sigmas))); ax3.set_xticklabels(sig_labels)
    ax3.set_yticks(range(len(mus))); ax3.set_yticklabels(mu_labels)
    ax3.set_xlabel('Volatility (σ)'); ax3.set_ylabel('Drift (μ)')
    ax3.set_title('Strategy Shift with Revision\n(RE Pctile − NR Pctile)')
    for ii in range(len(mus)):
        for jj in range(len(sigmas)):
            ax3.text(jj, ii, f"{int(shift[ii,jj]):+d}", ha='center', va='center', fontsize=7)
    plt.colorbar(im3, ax=ax3, label='Percentile shift')

    plt.suptitle('H1/H2/H3: Optimal Strategy and Option Value across Growth × Volatility',
                 fontsize=14, fontweight='bold', y=1.02)
    plt.tight_layout()
    plt.savefig('heatmap_mu_sigma.png', dpi=150, bbox_inches='tight')
    plt.show()

    print(f"  Heatmap complete. Max OV = {ov_grid.max():.1f}% at "
          f"mu={mus[np.unravel_index(ov_grid.argmax(), ov_grid.shape)[0]]:.0%}, "
          f"sigma={sigmas[np.unravel_index(ov_grid.argmax(), ov_grid.shape)[1]]:.0%}")
    print(f"{'='*80}\n")


